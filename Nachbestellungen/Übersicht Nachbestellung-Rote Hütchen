/***********************
 * QUEUE PROCESSOR
 ***********************/
function processQueue() {
  const MAX_LOCK_CYCLES = 8;
  for (let k = 0; k < MAX_LOCK_CYCLES; k++) {
    const lock = LockService.getScriptLock();
    if (!lock.tryLock(QUEUE_LOCK_WAIT_MS)) return;
    let processed = 0;
    try {
      processed = runQueueProcessor() || 0;
    } finally {
      try { lock.releaseLock(); } catch (e) {}
    }
    if (processed === 0) break;
    Utilities.sleep(150);
  }
}

function runQueueProcessor() {
  const ss = getMainSS();
  if (!ss) return 0;
  const queue = ss.getSheetByName("EventQueue");
  if (!queue) return 0;
  const last = queue.getLastRow();
  if (last < 2) return 0;

  const dashboard = ss.getSheetByName("Dashboard");
  const nbSheet = ss.getSheetByName("Nachbestellung");
  if (!dashboard || !nbSheet) return 0;

  const tagesMap = getTageslisteMap();
  const data = queue.getRange(1, 1, last, 10).getValues();

  const latestIdxByKey = {};
  for (let i = 1; i < data.length; i++) {
    if (data[i][6] !== "NEW") continue;
    if (data[i][1] === "_LOG") continue;
    const entryId = data[i][8] || "";
    const dedupKey = entryId
      ? "E:" + entryId
      : "S:" + (data[i][1] || "") + ":" + (data[i][2] || "");
    latestIdxByKey[dedupKey] = i;
  }

  let processedCount = 0;
  for (let i = 1; i < data.length; i++) {
    if (data[i][6] !== "NEW") continue;
    if (data[i][1] === "_LOG") continue;

    const entryId = data[i][8] || "";
    const dedupKey = entryId
      ? "E:" + entryId
      : "S:" + (data[i][1] || "") + ":" + (data[i][2] || "");

    if (latestIdxByKey[dedupKey] !== i) {
      queue.getRange(i + 1, 7).setValue("SKIPPED");
      continue;
    }

    if (processedCount >= MAX_EVENTS_PER_RUN) {
      logDebug("runQueueProcessor: Batch-Limit erreicht, Rest beim nächsten Lauf");
      break;
    }

    queue.getRange(i + 1, 7).setValue("PROCESSING");

    setLogUser(data[i][9] || "");

    try {
      const action = data[i][3];
      const snapshotKey = String(data[i][4] || "").trim();
      const sheetName = data[i][1] || "";
      const code = data[i][7] || "";
      let effectiveEntryId = entryId;

      if (!effectiveEntryId && !snapshotKey) {
        queue.getRange(i + 1, 7).setValue("DONE");
        continue;
      }

      if (action === "DELETE") {
        deleteEverywhere(snapshotKey, effectiveEntryId);
        queue.getRange(i + 1, 7).setValue("DONE");
        continue;
      }

      const inputSheet = INPUT_SHEETS[sheetName] ? ss.getSheetByName(sheetName) : null;
      let liveRow = -1;
      let liveData = null;
      let liveKey = snapshotKey;

      const inputEidCol = inputSheet ? getEntryIdCol(inputSheet) : 0;
      const queueRowNum = parseInt(data[i][2], 10) || 0;

      if (inputSheet && effectiveEntryId) {
        liveRow = findRowByEntryId(inputSheet, inputEidCol, effectiveEntryId, 2);
      }

      if (liveRow === -1 && inputSheet && queueRowNum >= 2 && snapshotKey) {
        try {
          const rowStock = String(inputSheet.getRange(queueRowNum, 2).getValue() || "").trim();
          if (rowStock.toUpperCase() === snapshotKey.toUpperCase()) {
            const rowEid = String(inputSheet.getRange(queueRowNum, inputEidCol).getValue() || "");
            liveRow = queueRowNum;
            if (rowEid) {
              if (effectiveEntryId && effectiveEntryId !== rowEid) {
                logDebug("queue: EID reconciled - queue had " + effectiveEntryId +
                  " but row " + queueRowNum + " has " + rowEid + " (using row-eid) for " + sheetName +
                  " stockId=" + snapshotKey);
              }
              effectiveEntryId = rowEid;
            } else {
              const newEid = effectiveEntryId || Utilities.getUuid();
              inputSheet.getRange(queueRowNum, inputEidCol).setValue(newEid);
              logDebug("queue: assigned EntryID " + newEid +
                " on " + sheetName + " row " + queueRowNum + " stockId=" + snapshotKey);
              effectiveEntryId = newEid;
            }
          }
        } catch (e) {}
      }

      if (liveRow === -1 && inputSheet && snapshotKey) {
        const inputLast = inputSheet.getLastRow();
        if (inputLast >= 2) {
          const stocks = inputSheet.getRange(2, 2, inputLast - 1, 1).getValues();
          const eidsCol = inputSheet.getRange(2, inputEidCol, inputLast - 1, 1).getValues();
          const target = snapshotKey.toUpperCase();
          let firstMatchRow = -1;
          let firstMatchEid = "";
          for (let r = 0; r < stocks.length; r++) {
            if (String(stocks[r][0] || "").trim().toUpperCase() === target) {
              const existingEid = String(eidsCol[r][0] || "");
              if (effectiveEntryId && existingEid === effectiveEntryId) {
                liveRow = r + 2;
                break;
              }
              if (firstMatchRow === -1) {
                firstMatchRow = r + 2;
                firstMatchEid = existingEid;
              }
            }
          }
          if (liveRow === -1 && firstMatchRow !== -1) {
            liveRow = firstMatchRow;
            if (firstMatchEid) {
              if (effectiveEntryId && effectiveEntryId !== firstMatchEid) {
                logDebug("queue: EID reconciled by stockId - queue had " + effectiveEntryId +
                  " but live row " + firstMatchRow + " has " + firstMatchEid + " for " + sheetName +
                  " stockId=" + snapshotKey);
              }
              effectiveEntryId = firstMatchEid;
            } else {
              const newEid = effectiveEntryId || Utilities.getUuid();
              inputSheet.getRange(firstMatchRow, inputEidCol).setValue(newEid);
              logDebug("queue: assigned EntryID " + newEid +
                " on " + sheetName + " row " + firstMatchRow + " (stockId fallback) stockId=" + snapshotKey);
              effectiveEntryId = newEid;
            }
          }
        }
      }

      if (liveRow !== -1) {
        liveData = inputSheet.getRange(liveRow, 1, 1, 6).getValues()[0];
        const liveStock = String(liveData[1] || "").trim();
        if (liveStock) liveKey = liveStock;
        if (!effectiveEntryId) {
          effectiveEntryId = ensureEntryIdOnInputRow(inputSheet, liveRow);
        }
      } else {
        logDebug("queue: UPDATE row not found, skipping (no destructive delete). " +
          "sheet=" + sheetName + " snapshotKey=" + snapshotKey + " entryId=" + effectiveEntryId);
        queue.getRange(i + 1, 7).setValue("SKIPPED_NO_ROW");
        continue;
      }

      if (!effectiveEntryId) {
        queue.getRange(i + 1, 7).setValue("DONE");
        continue;
      }

      if (!liveKey) {
        queue.getRange(i + 1, 7).setValue("DONE");
        continue;
      }

      const rowData = liveData ? liveData.slice() : [data[i][0], snapshotKey, "", "", "", ""];
      while (rowData.length < 6) rowData.push("");

      if (sheetName === "Input Exit" || code === "EX") {
        removeDashboardRowByEntryId(dashboard, effectiveEntryId);
        applyNachbestellungState(nbSheet, liveKey, rowData, effectiveEntryId);
        queue.getRange(i + 1, 7).setValue("DONE");
        continue;
      }

      processRow(rowData, liveKey, dashboard, nbSheet, tagesMap, code, false, effectiveEntryId);
      applyNachbestellungState(nbSheet, liveKey, rowData, effectiveEntryId);

      queue.getRange(i + 1, 7).setValue("DONE");
    } catch (err) {
      queue.getRange(i + 1, 7).setValue("ERROR: " + (err && err.message ? err.message : err));
    } finally {
      setLogUser("");
      processedCount++;
    }
  }
  return processedCount;
}

/***********************
 * DAYS BETWEEN
 ***********************/
function daysBetween(d1, d2) {
  const date1 = new Date(d1.getFullYear(), d1.getMonth(), d1.getDate());
  const date2 = new Date(d2.getFullYear(), d2.getMonth(), d2.getDate());
  return Math.abs(Math.floor((date1 - date2) / (1000 * 60 * 60 * 24)));
}

/***********************
 * MAIN PROCESSOR
 ***********************/
function processRow(data, key, dashboard, nbSheet, tagesMap, code, forceNB, entryId) {
  if (!key) return;

  const inputDate = data[0] ? new Date(data[0]) : new Date();
  const nb = getNachbestellungValuesByKey(nbSheet, key, entryId);
  const tages = tagesMap[key.toUpperCase()] || { count: 0, lastDate: "" };
  const baseDate = dashboard.getRange("A2").getValue()
    ? new Date(dashboard.getRange("A2").getValue())
    : new Date();

  let diffD = "";
  const rowDateC = tages.lastDate ? new Date(tages.lastDate) : null;
  if (rowDateC) diffD = daysBetween(baseDate, rowDateC);
  const diffI = daysBetween(baseDate, inputDate);

  const found = findRowByEntryId(dashboard, getEntryIdCol(dashboard), entryId, 4);

  let fVal = "", gVal = "", hVal = "";
  if (code) {
    fVal = code;
    gVal = data[2] || "";
    hVal = data[3] || "";
  } else if (found !== -1) {
    const dashVals = dashboard.getRange(found, 1, 1, 15).getValues()[0];
    fVal = dashVals[5] || "";
    gVal = dashVals[6] || "";
    hVal = dashVals[7] || "";
  }

  const dashEidCol = getEntryIdCol(dashboard);
  const dataWidth = Math.max(14, dashEidCol - 1);
  const rowData = new Array(dataWidth);
  rowData[0] = inputDate;
  rowData[1] = key;
  rowData[2] = tages.lastDate || "";
  rowData[3] = diffD;
  rowData[4] = tages.count || 0;
  rowData[5] = fVal;
  rowData[6] = gVal;
  rowData[7] = hVal;
  rowData[8] = diffI;
  rowData[9] = nb.i || "";
  rowData[10] = nb.k || "";
  rowData[11] = nb.l || "";
  rowData[12] = false;
  for (let c = 13; c < dataWidth; c++) rowData[c] = "";

  let targetRow;
  if (found !== -1) {
    targetRow = found;
  } else {
    targetRow = dashboard.getLastRow() + 1;
    if (dashboard.getLastRow() >= 4) {
      const allRows = dashboard.getRange(4, 2, dashboard.getLastRow() - 3, 1).getValues();
      for (let i = 0; i < allRows.length; i++) {
        if (allRows[i][0] === "" || allRows[i][0] === null) {
          targetRow = i + 4;
          break;
        }
      }
    } else {
      targetRow = 4;
    }
  }
  dashboard.getRange(targetRow, 1, 1, dataWidth).setValues([rowData]);
  dashboard.getRange(targetRow, dashEidCol).setValue(entryId);
  applyColor(dashboard.getRange(targetRow, 1, 1, 13), diffD);
}

/***********************
 * Nachbestellung lookup
 ***********************/
function getNachbestellungValuesByKey(nbSheet, key, entryId) {
  const last = nbSheet.getLastRow();
  if (last < 2) return { i: "", k: "", l: "" };
  const nbEidCol = getEntryIdCol(nbSheet);
  const width = Math.max(15, nbEidCol);
  const data = nbSheet.getRange(2, 1, last - 1, width).getValues();
  const keyU = String(key).toUpperCase();
  const eid = String(entryId || "");
  const eidIdx = nbEidCol - 1;
  for (let i = 0; i < data.length; i++) {
    if (
      String(data[i][1] || "").trim().toUpperCase() === keyU &&
      String(data[i][eidIdx] || "") === eid
    ) {
      return {
        i: data[i][8] || "",
        k: data[i][10] || "",
        l: data[i][11] || ""
      };
    }
  }
  return { i: "", k: "", l: "" };
}

/***********************
 * TAGESLISTE MAP
 ***********************/
function getTageslisteMap() {
  const ss = SpreadsheetApp.openById(SOURCE_ID);
  const sheet = ss.getSheetByName("Tagesliste");
  const map = {};
  if (!sheet) return map;
  const last = sheet.getLastRow();
  if (last < 2) return map;
  const data = sheet.getRange(1, 1, last, 5).getValues();
  for (let i = 1; i < data.length; i++) {
    const date = data[i][0];
    const key = String(data[i][4] || "").trim();
    if (!key) continue;
    const keyUpper = key.toUpperCase();
    if (!map[keyUpper]) {
      map[keyUpper] = { count: 0, lastDate: date };
    }
    map[keyUpper].count++;
    if (date && new Date(date) > new Date(map[keyUpper].lastDate)) {
      map[keyUpper].lastDate = date;
    }
  }
  return map;
}

/***********************
 * NACHBESTELLUNG UPDATE
 ***********************/
function updateNachbestellung(key, data, inputDate, nbSheet, entryId) {
  if (!key || key === "Stock ID" || !entryId) return;
  if (!nbSheet) return;

  const last = nbSheet.getLastRow();
  let foundRow = -1;
  if (last >= 2) {
    foundRow = findRowByEntryId(nbSheet, getEntryIdCol(nbSheet), entryId, 2);
  }

  const nbEidCol = getEntryIdCol(nbSheet);
  const dataWidth = Math.max(14, nbEidCol - 1);
  const oldVals = foundRow !== -1 ? nbSheet.getRange(foundRow, 1, 1, dataWidth).getValues()[0] : [];
  const rowData = new Array(dataWidth);
  rowData[0] = inputDate;
  rowData[1] = key;
  rowData[2] = data[4] || "";
  rowData[3] = data[5] || "";
  rowData[4] = data[3] || "";
  for (let c = 5; c < dataWidth; c++) {
    rowData[c] = oldVals[c] != null ? oldVals[c] : "";
  }

  const targetRow = foundRow !== -1 ? foundRow : Math.max(2, nbSheet.getLastRow() + 1);
  nbSheet.getRange(targetRow, 1, 1, dataWidth).setValues([rowData]);
  nbSheet.getRange(targetRow, nbEidCol).setValue(entryId);
}

/***********************
 * DELETE EVERYWHERE
 ***********************/
function deleteEverywhere(key, entryId) {
  const targetId = String(entryId || "").trim();
  if (!targetId) {
    logDebug("deleteEverywhere: REFUSED - no entryId. key=" + (key || "") +
      " (refusing to delete by StockID alone, would wipe duplicates with different entryIds)");
    return;
  }

  const targetKey = key ? String(key).trim().toUpperCase() : "";

  let dashRemoved = 0;
  let nbRemoved = 0;
  let inputRemoved = {};

  let ss = null;
  try { ss = getMainSS(); } catch (err) {}

  if (!ss) {
    logDebug("deleteEverywhere: cannot access main spreadsheet entryId=" + targetId);
    return;
  }

  try {
    const dashboard = ss.getSheetByName("Dashboard");
    if (dashboard && dashboard.getLastRow() >= 4) {
      const dashEidCol = getEntryIdCol(dashboard);
      let dRow;
      while ((dRow = findRowByEntryId(dashboard, dashEidCol, targetId, 4)) !== -1) {
        try {
          dashboard.deleteRow(dRow);
          dashRemoved++;
        } catch (e) {
          logDebug("deleteEverywhere dashboard delete failed row=" + dRow + ": " + e);
          break;
        }
      }
    }
  } catch (err) { logDebug("deleteEverywhere dashboard error: " + err); }

  try {
    const nbSheet = ss.getSheetByName("Nachbestellung");
    if (nbSheet && nbSheet.getLastRow() >= 2) {
      const nbEidCol = getEntryIdCol(nbSheet);
      let nbRow;
      while ((nbRow = findRowByEntryId(nbSheet, nbEidCol, targetId, 2)) !== -1) {
        try {
          nbSheet.deleteRow(nbRow);
          nbRemoved++;
        } catch (e) {
          logDebug("deleteEverywhere NB delete failed row=" + nbRow + ": " + e);
          break;
        }
      }
    }
  } catch (err) { logDebug("deleteEverywhere NB error: " + err); }

  INPUT_SHEET_NAMES.forEach(function (sheetName) {
    try {
      const s = ss.getSheetByName(sheetName);
      if (!s || s.getLastRow() < 2) return;
      const inputEidCol = getEntryIdCol(s);
      let count = 0;
      let inRow;
      while ((inRow = findRowByEntryId(s, inputEidCol, targetId, 2)) !== -1) {
        try {
          s.deleteRow(inRow);
          count++;
        } catch (e) {
          logDebug("deleteEverywhere " + sheetName + " delete failed row=" + inRow + ": " + e);
          break;
        }
      }
      if (count) inputRemoved[sheetName] = count;
    } catch (err) { logDebug("deleteEverywhere " + sheetName + " error: " + err); }
  });

  logDebug("deleteEverywhere: entryId=" + targetId + " key=" + targetKey +
    " dashboard=" + dashRemoved + " nb=" + nbRemoved +
    " inputs=" + JSON.stringify(inputRemoved) +
    " (Tagesliste intentionally untouched)");
}

/***********************
 * COLORS
 ***********************/
function applyColor(range, diffDays) {
  let color = "#ffffff";
  if (diffDays === "" || diffDays == null) {
    color = "#ffffff";
  } else if (diffDays <= 3) {
    color = "#d9f7d9";
  } else if (diffDays <= 10) {
    color = "#fff4cc";
  } else {
    color = "#ffd6d6";
  }
  range.getCell(1, 4).setBackground(color);
}

/***********************
 * ARCHIVIERUNG
 ***********************/
function archiveEntry(stockId) {
  if (!stockId) return;
  const ss = getMainSS();
  if (!ss) return;

  const archiveSheets = ["Dashboard_Archiv", "Nachbestellung_Archiv", "Input Exit_Archiv", "Input Q-Check_Archiv", "Input Mechanik_Archiv", "Input Lack_Archiv"];
  const origSheets = ["Dashboard", "Nachbestellung", "Input Exit", "Input Q-Check", "Input Mechanik", "Input Lack"];
  archiveSheets.forEach((name, idx) => {
    if (!ss.getSheetByName(name)) {
      const orig = ss.getSheetByName(origSheets[idx]);
      const newSheet = ss.insertSheet(name);
      if (orig && orig.getLastColumn() > 0) {
        newSheet.appendRow(orig.getRange(1, 1, 1, orig.getLastColumn()).getValues()[0]);
      }
    }
  });
  const source = SpreadsheetApp.openById(SOURCE_ID);
  if (!source.getSheetByName("Tagesliste_Archiv")) {
    const orig = source.getSheetByName("Tagesliste");
    const newSheet = source.insertSheet("Tagesliste_Archiv");
    if (orig && orig.getLastColumn() > 0) {
      newSheet.appendRow(orig.getRange(1, 1, 1, orig.getLastColumn()).getValues()[0]);
    }
  }

  moveRowToArchiveAndDelete(ss, "Dashboard", "Dashboard_Archiv", 2, stockId);
  moveRowToArchiveAndDelete(ss, "Nachbestellung", "Nachbestellung_Archiv", 2, stockId);
  moveRowToArchiveAndDelete(ss, "Input Exit", "Input Exit_Archiv", 2, stockId);
  moveRowToArchiveAndDelete(ss, "Input Q-Check", "Input Q-Check_Archiv", 2, stockId);
  moveRowToArchiveAndDelete(ss, "Input Mechanik", "Input Mechanik_Archiv", 2, stockId);
  moveRowToArchiveAndDelete(ss, "Input Lack", "Input Lack_Archiv", 2, stockId);
  moveRowToArchiveOnly(source, "Tagesliste", "Tagesliste_Archiv", 5, stockId);
}

function moveRowToArchiveAndDelete(ss, sheetName, archiveName, keyCol, stockId) {
  const sheet = ss.getSheetByName(sheetName);
  const archive = ss.getSheetByName(archiveName);
  if (!sheet || !archive) return;
  const last = sheet.getLastRow();
  if (last < 2) return;
  const data = sheet.getRange(1, 1, last, sheet.getLastColumn()).getValues();
  const target = String(stockId).trim().toUpperCase();
  for (let i = data.length - 1; i >= 1; i--) {
    if (String(data[i][keyCol - 1]).trim().toUpperCase() === target) {
      archive.appendRow(data[i]);
      sheet.deleteRow(i + 1);
    }
  }
}

function moveRowToArchiveOnly(ss, sheetName, archiveName, keyCol, stockId) {
  const sheet = ss.getSheetByName(sheetName);
  const archive = ss.getSheetByName(archiveName);
  if (!sheet || !archive) return;
  const last = sheet.getLastRow();
  if (last < 2) return;
  const data = sheet.getRange(1, 1, last, sheet.getLastColumn()).getValues();
  const target = String(stockId).trim().toUpperCase();
  for (let i = data.length - 1; i >= 1; i--) {
    if (String(data[i][keyCol - 1]).trim().toUpperCase() === target) {
      archive.appendRow(data[i]);
    }
  }
}

/***********************
 * Dashboard Cleanup: alle Input-Exit Einträge entfernen
 ***********************/
function cleanupDashboardOfInputExit() {
  const lock = LockService.getScriptLock();
  if (!lock.tryLock(QUEUE_LOCK_WAIT_MS)) return;
  try {
    const ss = getMainSS();
    if (!ss) return;
    const dashboard = ss.getSheetByName("Dashboard");
    const inputExit = ss.getSheetByName("Input Exit");
    if (!dashboard || !inputExit) return;

    const exitLast = inputExit.getLastRow();
    const exitIds = new Set();
    if (exitLast >= 2) {
      const eids = inputExit.getRange(2, getEntryIdCol(inputExit), exitLast - 1, 1).getValues();
      for (let i = 0; i < eids.length; i++) {
        const v = String(eids[i][0] || "");
        if (v) exitIds.add(v);
      }
    }

    const dashLast = dashboard.getLastRow();
    if (dashLast < 4) return;
    const dashEidCol = getEntryIdCol(dashboard);
    const dashEids = dashboard.getRange(4, dashEidCol, dashLast - 3, 1).getValues();
    const dashCodes = dashboard.getRange(4, 6, dashLast - 3, 1).getValues();
    let removed = 0;
    for (let i = dashEids.length - 1; i >= 0; i--) {
      const eid = String(dashEids[i][0] || "");
      const code = String(dashCodes[i][0] || "").trim().toUpperCase();
      if (code === "EX" || (eid && exitIds.has(eid))) {
        try { dashboard.deleteRow(i + 4); removed++; } catch (e) {}
      }
    }
    logDebug("cleanupDashboardOfInputExit: removed " + removed + " rows");
  } finally {
    try { lock.releaseLock(); } catch (e) {}
  }
}

/***********************
 * DASHBOARD TAGESDIFFERENZEN
 ***********************/
function updateDashboardDayDiffs() {
  const lock = LockService.getScriptLock();
  if (!lock.tryLock(QUEUE_LOCK_WAIT_MS)) return;
  try {
    const ss = getMainSS();
    const dashboard = ss.getSheetByName("Dashboard");
    if (!dashboard) return;
    const tagesMap = getTageslisteMap();
    const baseDate = dashboard.getRange("A2").getValue()
      ? new Date(dashboard.getRange("A2").getValue())
      : new Date();

    const lastRow = dashboard.getLastRow();
    if (lastRow < 4) return;

    const data = dashboard.getRange(4, 1, lastRow - 3, 15).getValues();
    for (let i = 0; i < data.length; i++) {
      const row = data[i];
      const inputDate = row[0] ? new Date(row[0]) : null;
      const key = String(row[1] || "").trim();
      if (!key) continue;
      const tages = tagesMap[key.toUpperCase()] || { count: 0, lastDate: "" };

      let diffD = "";
      const rowDateC = tages.lastDate ? new Date(tages.lastDate) : null;
      if (rowDateC) diffD = daysBetween(baseDate, rowDateC);

      let diffI = "";
      if (inputDate) diffI = daysBetween(baseDate, inputDate);

      if (row[3] !== diffD || row[8] !== diffI) {
        dashboard.getRange(i + 4, 4).setValue(diffD);
        dashboard.getRange(i + 4, 9).setValue(diffI);
        applyColor(dashboard.getRange(i + 4, 1, 1, 13), diffD);
      }
    }
  } finally {
    try { lock.releaseLock(); } catch (e) {}
  }
}

/***********************
 * Clear stale status-date when status itself is empty.
 * Nachbestellung: K (status, col 11) -> L (date, col 12)
 * Input Exit:     K (status, col 11) -> L (date, col 12)
 ***********************/
function clearStaleStatusDateOnSheet(sheet, statusCol, dateCol, label) {
  if (!sheet) return 0;
  const last = sheet.getLastRow();
  if (last < 2) return 0;

  const range = sheet.getRange(2, statusCol, last - 1, dateCol - statusCol + 1);
  const values = range.getValues();
  const dateIdx = dateCol - statusCol;
  let cleared = 0;
  for (let i = 0; i < values.length; i++) {
    const s = values[i][0];
    const d = values[i][dateIdx];
    const sEmpty = s === "" || s === null || (typeof s === "string" && s.trim() === "");
    const dFilled = d !== "" && d !== null && !(typeof d === "string" && d.trim() === "");
    if (sEmpty && dFilled) {
      values[i][dateIdx] = "";
      cleared++;
    }
  }
  if (cleared > 0) {
    range.setValues(values);
    logDebug("clearStaleStatusDate[" + label + "]: cleared " + cleared + " stale dates");
  }
  return cleared;
}

function cleanupNachbestellungStatusDate() {
  const lock = LockService.getScriptLock();
  if (!lock.tryLock(CLEANUP_LOCK_WAIT_MS)) return;
  try {
    const ss = getMainSS();
    if (!ss) return;
    clearStaleStatusDateOnSheet(ss.getSheetByName("Nachbestellung"), 11, 12, "Nachbestellung");
    clearStaleStatusDateOnSheet(ss.getSheetByName("Input Exit"), 11, 12, "Input Exit");
    try { reconcileNachbestellungInputExit(ss); } catch (err) { logDebug("reconcile failed: " + err); }
    try { cleanupEventQueue(ss); } catch (err) { logDebug("queue cleanup failed: " + err); }
  } finally {
    try { lock.releaseLock(); } catch (e) {}
  }
}

/***********************
 * EventQueue Cleanup
 * Löscht alte _LOG / DONE / SKIPPED / CANCELLED / ERROR Zeilen, damit
 * runQueueProcessor nicht ewig braucht. Geht zusammenhängend von oben,
 * stoppt bei der ersten Zeile, die behalten werden muss (z. B. NEW).
 ***********************/
function cleanupEventQueue(ss) {
  ss = ss || getMainSS();
  if (!ss) return;
  const queue = ss.getSheetByName("EventQueue");
  if (!queue) return;
  const last = queue.getLastRow();
  if (last < 200) return;

  const data = queue.getRange(2, 1, last - 1, 7).getValues();
  const now = Date.now();
  const LOG_TTL_MS = 4 * 60 * 60 * 1000;
  const DONE_TTL_MS = 6 * 60 * 60 * 1000;

  let deleteUpTo = 0;
  for (let i = 0; i < data.length; i++) {
    const ts = data[i][0];
    const action = data[i][1];
    const status = data[i][6];
    const tsMs = ts ? new Date(ts).getTime() : 0;
    const ageMs = tsMs ? (now - tsMs) : Infinity;
    const isLog = action === "_LOG";
    const isDone = status === "DONE" || status === "SKIPPED" || status === "CANCELLED" ||
      (typeof status === "string" && status.indexOf("ERROR") === 0);

    if (isLog && ageMs > LOG_TTL_MS) {
      deleteUpTo = i + 1;
    } else if (isDone && ageMs > DONE_TTL_MS) {
      deleteUpTo = i + 1;
    } else {
      break;
    }
  }

  if (deleteUpTo > 0) {
    queue.deleteRows(2, deleteUpTo);
    Logger.log("cleanupEventQueue: " + deleteUpTo + " Zeilen entfernt");
  }
}

/***********************
 * Reconciliation: gleicht Nachbestellung <-> Input Exit ab,
 * falls onEdit-Sync einen Update verpasst hat.
 * Mapping (NB <-> Exit):
 *   F (6)  <-> G (7)    Preis (Netto)
 *   I (9)  <-> I (9)    Cost Gate     (Exit H/8 = Claim Cost, kein NB-Pendant)
 *   J (10) <-> J (10)   Carol eingetragen
 *   K (11) <-> K (11)   Status
 *   L (12) <-> L (12)   Status-Datum
 ***********************/
function reconcileNachbestellungInputExit(ss) {
  ss = ss || getMainSS();
  if (!ss) return;
  const nbSheet = ss.getSheetByName("Nachbestellung");
  const exitSheet = ss.getSheetByName("Input Exit");
  if (!nbSheet || !exitSheet) return;

  const nbLast = nbSheet.getLastRow();
  const exitLast = exitSheet.getLastRow();
  if (nbLast < 2 || exitLast < 2) return;

  const exitEids = exitSheet.getRange(2, getEntryIdCol(exitSheet), exitLast - 1, 1).getValues();
  const exitStocks = exitSheet.getRange(2, 2, exitLast - 1, 1).getValues();
  // Read cols 7..12 (G..L). Col 8 (H = Claim Cost) is read but ignored in the mapping.
  const exitBlock = exitSheet.getRange(2, 7, exitLast - 1, 6).getValues();

  const exitByEid = {};
  const exitByStock = {};
  for (let i = 0; i < exitEids.length; i++) {
    const eid = String(exitEids[i][0] || "");
    if (eid) exitByEid[eid] = i;
    const stock = String(exitStocks[i][0] || "").trim().toUpperCase();
    if (stock && !(stock in exitByStock)) exitByStock[stock] = i;
  }

  const nbEids = nbSheet.getRange(2, getEntryIdCol(nbSheet), nbLast - 1, 1).getValues();
  const nbStocks = nbSheet.getRange(2, 2, nbLast - 1, 1).getValues();
  const nbBlockF = nbSheet.getRange(2, 6, nbLast - 1, 1).getValues();
  const nbBlockI = nbSheet.getRange(2, 9, nbLast - 1, 4).getValues();

  const isEmpty = function (v) {
    return v === "" || v === null || v === undefined || (typeof v === "string" && v.trim() === "");
  };
  const sameVal = function (a, b) {
    if (isEmpty(a) && isEmpty(b)) return true;
    if (a instanceof Date && b instanceof Date) return a.getTime() === b.getTime();
    return String(a) === String(b);
  };
  const tsMs = function (v) {
    if (!v) return 0;
    try { return new Date(v).getTime() || 0; } catch (e) { return 0; }
  };

  let nbWrites = 0;
  let exitWrites = 0;

  for (let i = 0; i < nbEids.length; i++) {
    const eid = String(nbEids[i][0] || "");
    const stock = String(nbStocks[i][0] || "").trim().toUpperCase();
    let xi = -1;
    if (eid && (eid in exitByEid)) xi = exitByEid[eid];
    else if (stock && (stock in exitByStock)) xi = exitByStock[stock];
    if (xi === -1) continue;

    const nbF = nbBlockF[i][0];
    const nbI = nbBlockI[i][0];
    const nbJ = nbBlockI[i][1];
    const nbK = nbBlockI[i][2];
    const nbL = nbBlockI[i][3];

    const exG = exitBlock[xi][0]; // col 7  Preis (Netto)
    // exitBlock[xi][1] = col 8 (Claim Cost) — Input-Exit-only, ignored here
    const exI = exitBlock[xi][2]; // col 9  Cost Gate
    const exJ = exitBlock[xi][3]; // col 10 Carol eingetragen
    const exK = exitBlock[xi][4]; // col 11 Status
    const exL = exitBlock[xi][5]; // col 12 Status-Datum

    const nbDate = tsMs(nbL);
    const exDate = tsMs(exL);
    const nbNewer = nbDate >= exDate;

    if (!sameVal(nbK, exK) || !sameVal(nbL, exL)) {
      if (nbNewer) {
        exitSheet.getRange(xi + 2, 11, 1, 2).setValues([[nbK, nbL]]);
        exitBlock[xi][4] = nbK; exitBlock[xi][5] = nbL;
        exitWrites++;
      } else {
        nbSheet.getRange(i + 2, 11, 1, 2).setValues([[exK, exL]]);
        nbBlockI[i][2] = exK; nbBlockI[i][3] = exL;
        nbWrites++;
      }
    }

    if (!sameVal(nbF, exG)) {
      if (isEmpty(nbF) && !isEmpty(exG)) {
        nbSheet.getRange(i + 2, 6).setValue(exG);
        nbWrites++;
      } else if (!isEmpty(nbF) && isEmpty(exG)) {
        exitSheet.getRange(xi + 2, 7).setValue(nbF);
        exitWrites++;
      }
    }
    if (!sameVal(nbI, exI)) {
      if (isEmpty(nbI) && !isEmpty(exI)) {
        nbSheet.getRange(i + 2, 9).setValue(exI);
        nbWrites++;
      } else if (!isEmpty(nbI) && isEmpty(exI)) {
        exitSheet.getRange(xi + 2, 9).setValue(nbI);
        exitWrites++;
      }
    }
    if (!sameVal(nbJ, exJ)) {
      if (isEmpty(nbJ) && !isEmpty(exJ)) {
        nbSheet.getRange(i + 2, 10).setValue(exJ);
        nbWrites++;
      } else if (!isEmpty(nbJ) && isEmpty(exJ)) {
        exitSheet.getRange(xi + 2, 10).setValue(nbJ);
        exitWrites++;
      }
    }
  }

  if (nbWrites || exitWrites) {
    logDebug("reconcileNachbestellungInputExit: NB writes=" + nbWrites + " Exit writes=" + exitWrites);
  }
}

function installCleanupNachbestellungStatusDateTrigger() {
  const triggers = ScriptApp.getProjectTriggers();
  for (let i = 0; i < triggers.length; i++) {
    if (triggers[i].getHandlerFunction() === "cleanupNachbestellungStatusDate") {
      ScriptApp.deleteTrigger(triggers[i]);
    }
  }
  ScriptApp.newTrigger("cleanupNachbestellungStatusDate")
    .timeBased()
    .everyMinutes(1)
    .create();
}
