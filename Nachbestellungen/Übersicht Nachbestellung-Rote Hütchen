 * Sync helpers
 ***********************/
function syncInputRowToNachbestellung(sheet, row) {
  let entryId = sheet.getRange(row, getEntryIdCol(sheet)).getValue() || "";
  const data = sheet.getRange(row, 1, 1, 6).getValues()[0];
  const stockId = String(data[1] || "").trim();
  if (!stockId) return;
  if (!entryId) {
    entryId = ensureEntryIdOnInputRow(sheet, row);
    if (!entryId) return;
  }
  const ss = getMainSS();
  if (!ss) return;
  const nbSheet = ss.getSheetByName("Nachbestellung");
  if (!nbSheet) return;
  applyNachbestellungState(nbSheet, stockId, data, entryId);
}

function syncNachbestellungColumnToInputExit(nbSheet, row, srcCol, targetCol) {
  let stockId = "";
  try { stockId = String(nbSheet.getRange(row, 2).getValue() || "").trim(); } catch (e) {}
  let entryId = "";
  try { entryId = String(nbSheet.getRange(row, getEntryIdCol(nbSheet)).getValue() || ""); } catch (e) {}

  if (!stockId && !entryId) {
    logDebug("syncToExit: no stockId/entryId in Nachbestellung row " + row);
    return;
  }

  let value;
