function normalizeExitStatus(val) {
  if (val === null || val === undefined) return val;
  let s = String(val)
    .replace(/\u00a0/g, " ")
    .trim()
    .replace(/\s+/g, " ");
  if (s === "") return "";
  if (typeof s.normalize === "function") s = s.normalize("NFC");
  const lower = s.toLowerCase();
  for (let i = 0; i < EXIT_STATUS_CANONICAL.length; i++) {
    let cmp = EXIT_STATUS_CANONICAL[i];
    if (typeof cmp.normalize === "function") cmp = cmp.normalize("NFC");
    if (cmp.toLowerCase() === lower) {
      return EXIT_STATUS_CANONICAL[i];
    }
  }
  return s;
}

function syncStockStatusToInputSheets(stockId, statusValue) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  if (!ss) return 0;
  const key = String(stockId || "").trim().toUpperCase();
  if (!key) return 0;
  const sh = ss.getSheetByName("Input Exit");
  if (!sh) return 0;
  const lr = sh.getLastRow();
  if (lr < 2) return 0;
  const outVal = normalizeExitStatus(statusValue);
  const ids = sh.getRange(2, 2, lr, 2).getValues();
  let updated = 0;
  for (let r = 0; r < ids.length; r++) {
    if (String(ids[r][0] || "").trim().toUpperCase() === key) {
      const tgt = sh.getRange(r + 2, INPUT_STATUS_COL);
      tgt.clearContent();
      tgt.setValue(outVal);
      updated++;
    }
  }
  SpreadsheetApp.flush();
  return updated;
}

/***********************
 * ONEDIT → Queue, Datum, Zeitstempel, Dashboard-Update, Delete, Sync, Archivierung
 ***********************/
function onEdit(e) {
  const sheet = e.range.getSheet();
  const name = sheet.getName();
  const row = e.range.getRow();
  const col = e.range.getColumn();

  // --- Zellschutz für Spalte B in den vier Input-Sheets ---
  const inputSheets = ["Input Q-Check", "Input Mechanik", "Input Lack", "Input Exit"];
  if (inputSheets.indexOf(name) !== -1 && col === 2 && row >= 2) {
    const range = sheet.getRange(row, 2);
    const protections = sheet.getProtections(SpreadsheetApp.ProtectionType.RANGE);
    for (let i = protections.length - 1; i >= 0; i--) {
      if (protections[i].getRange().getA1Notation() === range.getA1Notation()) {
        protections[i].remove();
      }
    }
    const value = range.getValue();
    if (value) {
      const owner = SpreadsheetApp.getActiveSpreadsheet().getOwner().getEmail();
      const protection = range.protect();
      protection.setDescription("Nur berechtigte Personen dürfen diese Stock ID ändern");
      protection.removeEditors(protection.getEditors());
      protection.addEditor(owner);
      protection.addEditor("helmut.mirbeth@auto1.com");
      protection.addEditor("bastian.frankhauser@auto1.com");
      protection.addEditor("joerg.eichenseher@auto1.com");
      protection.setWarningOnly(false);
    }
  }

  // 1. Stock ID in Input-Sheets immer in Großbuchstaben umwandeln
  if (INPUT_SHEETS[name] && col === 2 && row >= 2) {
    let cell = sheet.getRange(row, 2);
    let val = cell.getValue();
    if (val && val !== val.toUpperCase()) {
      cell.setValue(val.toUpperCase());
      return;
    }
    // EntryID vergeben, falls leer
    let entryIdCell = sheet.getRange(row, ENTRYID_COL);
    if (!entryIdCell.getValue() && val) {
      entryIdCell.setValue(Utilities.getUuid());
    }
  }

  // --- Nur wenn in Spalte C "Ja" steht, Nachbestellung aktualisieren, sonst löschen ---
  if (inputSheets.indexOf(name) !== -1 && col === 3 && row >= 2) {
    const valueC = String(sheet.getRange(row, 3).getValue() || "").trim().toLowerCase();
    const stockId = String(sheet.getRange(row, 2).getValue() || "").trim();
    const entryId = sheet.getRange(row, ENTRYID_COL).getValue() || "";
    const nbSheet = SpreadsheetApp.openById(MAIN_ID).getSheetByName("Nachbestellung");
    if (valueC === "ja") {
      let data = sheet.getRange(row, 1, 1, 6).getValues()[0];
      updateNachbestellung(stockId, data, data[0] ? new Date(data[0]) : new Date(), nbSheet, entryId);
    } else {
      deleteNachbestellungByEntryId(nbSheet, entryId);
    }
  }

  // NEU: Wenn in Input Exit Spalte L etwas geändert wird UND L nicht leer ist, synchronisiere ins Zielsheet
  if (name === "Input Exit" && col === 12 && row >= 2) {
    let valueL = sheet.getRange(row, 12).getValue();
    if (valueL !== "" && valueL !== null) {
      let result = syncInputExitToZielSheetRow(row);
      sheet.getRange(row, 13).setValue(result); // Rückmeldung in Spalte M
    } else {
      sheet.getRange(row, 13).setValue(""); // Spalte M leeren, wenn L leer
    }
  }

  // Archivierung per Checkbox in Dashboard!M (stabil, ohne Dialog)
  if (name === "Dashboard" && col === 13 && row >= 3) { // Spalte M = 13
    const value = sheet.getRange(row, col).getValue();
    const stockId = sheet.getRange(row, 2).getValue();
    if (value === true && stockId) {
      archiveEntry(stockId);
      sheet.getRange(row, col).setValue(false);
      return;
    }
  }

  // --- Nur noch F (Nachbestellung) → G (Input Exit) ---
  if (name === "Nachbestellung" && row >= 2 && col === 6) {
    const stockId = sheet.getRange(row, 2).getValue();
    if (!stockId) return;
    const ss = SpreadsheetApp.openById(MAIN_ID);
    const exitSheet = ss.getSheetByName("Input Exit");
    const exitData = exitSheet.getDataRange().getValues();
    for (let r = 1; r < exitData.length; r++) {
      if (String(exitData[r][1]).trim().toUpperCase() === String(stockId).trim().toUpperCase()) {
        exitSheet.getRange(r + 1, 7).setValue(sheet.getRange(row, 6).getValue());
        break;
      }
    }
    return;
  }

  // Zeitstempel in Input Exit: Wenn sich in J (10) etwas ändert, schreibe Zeitstempel in K (11)
  if (name === "Input Exit" && col === 10 && row >= 2) {
    sheet.getRange(row, 11).setValue(new Date());
  }

  // 1. Automatisches Datum in Spalte A, wenn in B etwas eingetragen wird
  if (INPUT_SHEETS[name] && col === 2 && row >= 2) {
    const dateCell = sheet.getRange(row, 1);
    if (!dateCell.getValue() && sheet.getRange(row, 2).getValue()) {
      dateCell.setValue(new Date());
    }
  }

  // 2. Wenn in Inputs B gelöscht wird, lösche die Zeile überall!
  if (INPUT_SHEETS[name] && col === 2 && row >= 2 && !sheet.getRange(row, 2).getValue()) {
    let entryId = sheet.getRange(row, ENTRYID_COL).getValue() || "";
    let key = e.oldValue || "";
    if (key && entryId) {
      deleteEverywhere(key, entryId);
    }
    sheet.deleteRow(row);
    return;
  }

  if (name === "Nachbestellung" && row >= 2) {
    const nbRange = e.range;
    const kCol = 11;
    if (nbRange.getColumn() <= kCol && nbRange.getLastColumn() >= kCol) {
      const r0 = Math.max(2, nbRange.getRow());
      const r1 = nbRange.getLastRow();
      for (let r = r0; r <= r1; r++) {
        const valK =
          nbRange.getNumRows() === 1 && nbRange.getNumColumns() === 1 && col === kCol ? e.value : sheet.getRange(r, kCol).getValue();
        sheet.getRange(r, 12).setValue(new Date());
        const sid = String(sheet.getRange(r, 2).getValue() || "").trim();
        if (sid) {
          const updated = syncStockStatusToInputSheets(sid, valK);
          if (updated > 0) {
            const ssToast = SpreadsheetApp.getActiveSpreadsheet();
            if (ssToast) {
              const st = normalizeExitStatus(valK);
              const stStr =
                st === "" || st === null || st === undefined ? "—" : String(st);
              ssToast.toast(
                sid + "\nStatus → " + stStr + "\n- Input Exit · " + updated + " Zeile(n)",
                "Exit-Sync · OK",
                -1
              );
            }
          }
        }
      }
    }
  }

  // 4. Dashboard aktualisieren, wenn in Nachbestellung I, K, L geändert wird
  if (name === "Nachbestellung" && [9, 11, 12].includes(col) && row >= 2) {
    const key = String(sheet.getRange(row, 2).getValue()).trim();
    if (key) {
      const ss = SpreadsheetApp.openById(MAIN_ID);
      const dashboard = ss.getSheetByName("Dashboard");
      const nbSheet = sheet;
      const tagesMap = getTageslisteMap();
      const entryId = sheet.getRange(row, NB_ENTRYID_COL).getValue() || "";

      const lastRow = dashboard.getLastRow();
      const entryIds = dashboard.getRange(4, DASHBOARD_ENTRYID_COL, Math.max(0, lastRow - 3), 1).getValues();
      let dashboardRow = -1;
      for (let i = 0; i < entryIds.length; i++) {
        if (String(entryIds[i][0]) === entryId) {
          dashboardRow = i + 4;
          break;
        }
      }

      let fVal = "", gVal = "", hVal = "";
      if (dashboardRow !== -1) {
        let dashVals = dashboard.getRange(dashboardRow, 1, 1, 15).getValues()[0];
        fVal = dashVals[5] || "";
        gVal = dashVals[6] || "";
        hVal = dashVals[7] || "";
      }

      let data = [
        sheet.getRange(row, 1).getValue(),
        key,
        "", "", "", "",
        fVal,
        gVal,
        hVal
      ];

      processRow(data, key, dashboard, nbSheet, tagesMap, "", true, entryId);
    }
  }

  // 5. Queue-Mechanismus wie gehabt, Input Exit wird in die Queue geschrieben (aber nicht ins Dashboard übernommen)
  if (!INPUT_SHEETS[name]) return;
  if (row < 2) return;

  const data = sheet.getRange(row, 1, 1, 6).getValues()[0];
  const key = String(data[1] || "").trim();
  const code = INPUT_SHEETS[name] || "";
  const entryId = sheet.getRange(row, ENTRYID_COL).getValue() || "";

  const ss = SpreadsheetApp.openById(MAIN_ID);
  const queue = ss.getSheetByName("EventQueue");

  queue.appendRow([
    new Date(),
    name,
    row,
    key ? "UPDATE" : "DELETE",
    key,
    JSON.stringify(data),
    "NEW",
    code,
    entryId
  ]);
}

// Hilfsfunktion zum gezielten Löschen in Nachbestellung
function deleteNachbestellungByEntryId(nbSheet, entryId) {
  if (!entryId) return;
  const lastRow = nbSheet.getLastRow();
  if (lastRow < 2) return;
  const values = nbSheet.getRange(2, NB_ENTRYID_COL, lastRow - 1, 1).getValues();
  for (let i = values.length - 1; i >= 0; i--) {
    if (String(values[i][0]) === entryId) {
      nbSheet.deleteRow(i + 2);
    }
  }
}

/***********************
 * NEU: Übertrage nur die geänderte Zeile, nur wenn L nicht leer ist
 ***********************/
function syncInputExitToZielSheetRow(inputRow) {
  try {
    const inputExit = SpreadsheetApp.openById(MAIN_ID).getSheetByName("Input Exit");
    const stockId = String(inputExit.getRange(inputRow, 2).getValue() || "").trim().toUpperCase();
    const valueL = inputExit.getRange(inputRow, 12).getValue();

    if (!stockId || valueL === "" || valueL === null) {
      return "Kein Wert/StockID";
    }

    const zielSheet = SpreadsheetApp.openById(ZIELSHEET_ID).getSheetByName(ZIELSHEET_NAME);
    const zielData = zielSheet.getDataRange().getValues();

    for (let i = 1; i < zielData.length; i++) {
      let zielStockId = String(zielData[i][0] || "").trim().toUpperCase();
      if (zielStockId === stockId) {
        zielSheet.getRange(i + 1, 5).setValue(valueL); // Spalte E
        return "Übertragen";
      }
    }
    return "StockID nicht gefunden";
  } catch (err) {
    return "Fehler: " + err;
  }
}

/***********************
 * QUEUE PROCESSOR
 ***********************/
function processQueue() {
  const ss = SpreadsheetApp.openById(MAIN_ID);

  const queue = ss.getSheetByName("EventQueue");
  const dashboard = ss.getSheetByName("Dashboard");
  const nbSheet = ss.getSheetByName("Nachbestellung");

  const tagesMap = getTageslisteMap();

  const data = queue.getDataRange().getValues();

  for (let i = 1; i < data.length; i++) {
    if (data[i][6] !== "NEW") continue;

    const action = data[i][3];
    const key = String(data[i][4] || "").trim();
    const sheetName = data[i][1] || "";
    const inputRow = data[i][2];
    let rowData;
    let code = data[i][7] || "";
    const entryId = data[i][8] || "";

    try {
      rowData = JSON.parse(data[i][5] || "[]");
    } catch (e) {
      queue.getRange(i + 1, 7).setValue("ERROR_JSON");
      continue;
    }

    if (!key) {
      queue.getRange(i + 1, 7).setValue("DONE");
      continue;
    }

    if (action === "DELETE") {
      deleteEverywhere(key, entryId);
      queue.getRange(i + 1, 7).setValue("DONE");
      continue;
    }

    // Input Exit wird NICHT ins Dashboard übernommen, sondern nur Nachbestellung synchronisiert!
    if (sheetName === "Input Exit" || code === "EX") {
      // Prüfe, ob in Input Exit Spalte C "Ja" steht, sonst lösche aus Nachbestellung
      const inputExit = ss.getSheetByName("Input Exit");
      let foundRow = -1;
      const entryIds = inputExit.getRange(2, ENTRYID_COL, inputExit.getLastRow() - 1, 1).getValues();
      for (let r = 0; r < entryIds.length; r++) {
        if (String(entryIds[r][0]) === entryId) {
          foundRow = r + 2;
          break;
        }
      }
      let valueC = "";
      if (foundRow !== -1) {
        valueC = String(inputExit.getRange(foundRow, 3).getValue() || "").trim().toLowerCase();
      }
      if (valueC === "ja") {
        updateNachbestellung(key, rowData, rowData[0] ? new Date(rowData[0]) : new Date(), nbSheet, entryId);
      } else {
        deleteNachbestellungByEntryId(nbSheet, entryId);
      }
      queue.getRange(i + 1, 7).setValue("DONE");
      continue;
    }

    // rowData ggf. auf 6 Felder erweitern
    while (rowData.length < 6) rowData.push("");

    processRow(rowData, key, dashboard, nbSheet, tagesMap, code, false, entryId);

    // --- NUR wenn in Spalte C "Ja" steht, in Nachbestellung übernehmen ---
    if (
      (sheetName === "Input Q-Check" || sheetName === "Input Mechanik" || sheetName === "Input Lack") &&
      String(rowData[2]).trim().toLowerCase() === "ja"
    ) {
      updateNachbestellung(key, rowData, rowData[0] ? new Date(rowData[0]) : new Date(), nbSheet, entryId);
    } else if (
      (sheetName === "Input Q-Check" || sheetName === "Input Mechanik" || sheetName === "Input Lack") &&
      String(rowData[2]).trim().toLowerCase() !== "ja"
    ) {
      deleteNachbestellungByEntryId(nbSheet, entryId);
    }

    queue.getRange(i + 1, 7).setValue("DONE");
  }
}

/***********************
 * DAYS BETWEEN (Datum ohne Uhrzeit!)
 ***********************/
function daysBetween(d1, d2) {
  var date1 = new Date(d1.getFullYear(), d1.getMonth(), d1.getDate());
  var date2 = new Date(d2.getFullYear(), d2.getMonth(), d2.getDate());
  return Math.abs(Math.floor((date1 - date2) / (1000 * 60 * 60 * 24)));
}

/***********************
 * MAIN PROCESSOR (Dashboard ab Zeile 4, immer nächste freie Zeile)
 ***********************/
function processRow(data, key, dashboard, nbSheet, tagesMap, code, forceNB, entryId) {
  if (!key) return;

  const inputDate = data[0] ? new Date(data[0]) : new Date();
  const nb = getNachbestellungValuesByKey(nbSheet, key, entryId);
  const tages = tagesMap[key.toUpperCase()] || { count: 0, lastDate: "" };
  const baseDate = dashboard.getRange("A2").getValue()
    ? new Date(dashboard.getRange("A2").getValue())
    : new Date();
  let diffD = "";
  let rowDateC = tages.lastDate ? new Date(tages.lastDate) : null;
  if (rowDateC) {
    diffD = daysBetween(baseDate, rowDateC);
  }
  const diffI = daysBetween(baseDate, inputDate);

  const lastRow = dashboard.getLastRow();
  const values = dashboard.getRange(4, DASHBOARD_ENTRYID_COL, Math.max(0, lastRow - 3), 1).getValues();
  let found = -1;
  for (let i = 0; i < values.length; i++) {
    if (String(values[i][0]) === entryId) {
      found = i + 4;
      break;
    }
  }

  let fVal = "", gVal = "", hVal = "";
  if (code) {
    fVal = code;
    gVal = data[2] || "";
    hVal = data[3] || "";
  } else if (found !== -1) {
    let dashVals = dashboard.getRange(found, 1, 1, 15).getValues()[0];
    fVal = dashVals[5] || "";
    gVal = dashVals[6] || "";
    hVal = dashVals[7] || "";
  }

  let rowData = [
    inputDate, key, tages.lastDate || "", diffD, tages.count || 0,
    fVal, gVal, hVal, diffI,
    nb.i || "", nb.k || "", nb.l || "", false,
    "", // Spalte N (frei)
    entryId // Spalte O (EntryID)
  ];

  if (found !== -1) {
    dashboard.getRange(found, 1, 1, 15).setValues([rowData]);
    applyColor(dashboard.getRange(found, 1, 1, 13), diffD);
  } else {
    let insertRow = dashboard.getLastRow() + 1;
    const allRows = dashboard.getRange(4, 2, Math.max(0, dashboard.getLastRow() - 3), 1).getValues();
    for (let i = 0; i < allRows.length; i++) {
      let isEmpty = allRows[i][0] === "" || allRows[i][0] === null;
      if (isEmpty) {
        insertRow = i + 4;
        break;
      }
    }
    dashboard.getRange(insertRow, 1, 1, 15).setValues([rowData]);
    applyColor(dashboard.getRange(insertRow, 1, 1, 13), diffD);
  }
}

/***********************
 * Holt aktuelle Werte aus Nachbestellung (I, K, L) – jetzt mit EntryID!
 ***********************/
function getNachbestellungValuesByKey(nbSheet, key, entryId) {
  const data = nbSheet.getDataRange().getValues();
  for (let i = 1; i < data.length; i++) {
    if (
      String(data[i][1] || "").trim().toUpperCase() === key.toUpperCase() &&
      String(data[i][14] || "") === entryId
    ) {
      return {
        i: data[i][8] || "",
        k: data[i][10] || "",
        l: data[i][11] || ""
      };
    }
  }
  return {i: "", k: "", l: ""};
}

/***********************
 * TAGESLISTE MAP
 ***********************/
function getTageslisteMap() {
  const ss = SpreadsheetApp.openById(SOURCE_ID);
  const sheet = ss.getSheetByName("Tagesliste");

  const data = sheet.getDataRange().getValues();

  const map = {};

  for (let i = 1; i < data.length; i++) {
    const date = data[i][0];
    const key = String(data[i][4] || "").trim();
    if (!key) continue;
    const keyUpper = key.toUpperCase();

    if (!map[keyUpper]) {
      map[keyUpper] = { count: 0, lastDate: date };
    }

    map[keyUpper].count++;

    if (new Date(date) > new Date(map[keyUpper].lastDate)) {
      map[keyUpper].lastDate = date;
    }
  }

  return map;
}

/***********************
 * NACHBESTELLUNG UPDATE (Input-Daten übertragen, Rest bleibt!)
 ***********************/
function updateNachbestellung(key, data, inputDate, nbSheet, entryId) {
  if (!key || key === "Stock ID") return;

  const lastRow = nbSheet.getLastRow();
  if (lastRow < 2) return;

  const values = nbSheet.getRange(2, NB_ENTRYID_COL, lastRow - 1, 1).getValues();

  let foundRow = -1;
  for (let i = 0; i < values.length; i++) {
    if (String(values[i][0]) === entryId) {
      foundRow = i + 2;
      break;
    }
  }

  let oldVals = foundRow !== -1 ? nbSheet.getRange(foundRow, 1, 1, 15).getValues()[0] : [];
  let rowData = [
    inputDate,         // A
    key,               // B
    data[4] || "",     // C (Input Spalte E)
    data[5] || "",     // D (Input Spalte F)
    data[3] || "",     // E (Input Spalte D)
    oldVals[5] || "",  // F
    oldVals[6] || "",  // G
    oldVals[7] || "",  // H
    oldVals[8] || "",  // I
    oldVals[9] || "",  // J
    oldVals[10] || "", // K
    oldVals[11] || "", // L
    oldVals[12] || "", // M
    oldVals[13] || "", // N
    entryId // Spalte O (EntryID)
  ];

  if (foundRow !== -1) {
    nbSheet.getRange(foundRow, 1, 1, 15).setValues([rowData]);
  } else {
    nbSheet.getRange(nbSheet.getLastRow() + 1, 1, 1, 15).setValues([rowData]);
  }
}

/***********************
 * DELETE SYSTEM (löscht gezielt nach EntryID)
 ***********************/
function deleteEverywhere(key, entryId) {
  if (!key || !entryId) return;
  const ss = SpreadsheetApp.openById(MAIN_ID);

  // Dashboard
  const dashboard = ss.getSheetByName("Dashboard");
  const d = dashboard.getRange(4, DASHBOARD_ENTRYID_COL, Math.max(0, dashboard.getLastRow() - 3), 1).getValues();
  for (let i = d.length - 1; i >= 0; i--) {
    if (String(d[i][0]) === entryId) {
      dashboard.deleteRow(i + 4);
    }
  }

  // Nachbestellung
  const nbSheet = ss.getSheetByName("Nachbestellung");
  const n = nbSheet.getRange(2, NB_ENTRYID_COL, nbSheet.getLastRow() - 1, 1).getValues();
  for (let i = n.length - 1; i >= 0; i--) {
    if (String(n[i][0]) === entryId) {
      nbSheet.deleteRow(i + 2);
    }
  }

  // Tagesliste (im SOURCE_ID) – bleibt wie gehabt, da keine EntryID dort
  const source = SpreadsheetApp.openById(SOURCE_ID);
  const tagesSheet = source.getSheetByName("Tagesliste");
  const t = tagesSheet.getRange(2, 5, tagesSheet.getLastRow() - 1, 1).getValues();
  for (let i = t.length - 1; i >= 0; i--) {
    if (String(t[i][0]).trim().toUpperCase() === key.toUpperCase()) {
      tagesSheet.deleteRow(i + 2);
    }
  }
}

/***********************
 * FARBEN FÜR DASHBOARD D
 ***********************/
function applyColor(range, diffDays) {
  let color = "#ffffff";
  if (diffDays === "" || diffDays == null) {
    color = "#ffffff";
  } else if (diffDays <= 3) {
    color = "#d9f7d9";
  } else if (diffDays <= 10) {
    color = "#fff4cc";
  } else {
    color = "#ffd6d6";
  }
  range.getCell(1, 4).setBackground(color); // Spalte D im Range
}

/***********************
 * ARCHIVIERUNG
 ***********************/
function archiveEntry(stockId) {
  if (!stockId) return;
  const ss = SpreadsheetApp.openById(MAIN_ID);

  const archiveSheets = ["Dashboard_Archiv", "Nachbestellung_Archiv", "Input Exit_Archiv", "Input Q-Check_Archiv", "Input Mechanik_Archiv", "Input Lack_Archiv"];
  const origSheets = ["Dashboard", "Nachbestellung", "Input Exit", "Input Q-Check", "Input Mechanik", "Input Lack"];
  archiveSheets.forEach((name, idx) => {
    if (!ss.getSheetByName(name)) {
      const orig = ss.getSheetByName(origSheets[idx]);
      let newSheet = ss.insertSheet(name);
      if (orig) {
        newSheet.appendRow(orig.getRange(1, 1, 1, orig.getLastColumn()).getValues()[0]);
      }
    }
  });
  const source = SpreadsheetApp.openById(SOURCE_ID);
  if (!source.getSheetByName("Tagesliste_Archiv")) {
    const orig = source.getSheetByName("Tagesliste");
    let newSheet = source.insertSheet("Tagesliste_Archiv");
    if (orig) {
      newSheet.appendRow(orig.getRange(1, 1, 1, orig.getLastColumn()).getValues()[0]);
    }
  }

  moveRowToArchiveAndDelete(ss, "Dashboard", "Dashboard_Archiv", 2, stockId);
  moveRowToArchiveAndDelete(ss, "Nachbestellung", "Nachbestellung_Archiv", 2, stockId);
  moveRowToArchiveAndDelete(ss, "Input Exit", "Input Exit_Archiv", 2, stockId);
  moveRowToArchiveAndDelete(ss, "Input Q-Check", "Input Q-Check_Archiv", 2, stockId);
  moveRowToArchiveAndDelete(ss, "Input Mechanik", "Input Mechanik_Archiv", 2, stockId);
  moveRowToArchiveAndDelete(ss, "Input Lack", "Input Lack_Archiv", 2, stockId);
  moveRowToArchiveOnly(source, "Tagesliste", "Tagesliste_Archiv", 5, stockId);
}

function moveRowToArchiveAndDelete(ss, sheetName, archiveName, keyCol, stockId) {
  const sheet = ss.getSheetByName(sheetName);
  const archive = ss.getSheetByName(archiveName);
  if (!sheet || !archive) return;
  const data = sheet.getDataRange().getValues();
  for (let i = data.length - 1; i >= 1; i--) {
    if (String(data[i][keyCol - 1]).trim().toUpperCase() === String(stockId).trim().toUpperCase()) {
      archive.appendRow(data[i]);
      sheet.deleteRow(i + 1);
    }
  }
}

function moveRowToArchiveOnly(ss, sheetName, archiveName, keyCol, stockId) {
  const sheet = ss.getSheetByName(sheetName);
  const archive = ss.getSheetByName(archiveName);
  if (!sheet || !archive) return;
  const data = sheet.getDataRange().getValues();
  for (let i = data.length - 1; i >= 1; i--) {
    if (String(data[i][keyCol - 1]).trim().toUpperCase() === String(stockId).trim().toUpperCase()) {
      archive.appendRow(data[i]);
    }
  }
}

/***********************
 * DASHBOARD TAGESDIFFERENZEN (Spalte D und I) AKTUALISIEREN
 ***********************/
function updateDashboardDayDiffs() {
  const ss = SpreadsheetApp.openById(MAIN_ID);
  const dashboard = ss.getSheetByName("Dashboard");
  const tagesMap = getTageslisteMap();
  const baseDate = dashboard.getRange("A2").getValue()
    ? new Date(dashboard.getRange("A2").getValue())
    : new Date();

  const lastRow = dashboard.getLastRow();
  if (lastRow < 4) return;

  const data = dashboard.getRange(4, 1, lastRow - 3, 15).getValues();

  for (let i = 0; i < data.length; i++) {
    const row = data[i];
    const inputDate = row[0] ? new Date(row[0]) : null;
    const key = String(row[1] || "").trim();
    const tages = tagesMap[key.toUpperCase()] || { count: 0, lastDate: "" };

    let diffD = "";
    let rowDateC = tages.lastDate ? new Date(tages.lastDate) : null;
    if (rowDateC) {
      diffD = daysBetween(baseDate, rowDateC);
    }

    let diffI = "";
    if (inputDate) {
      diffI = daysBetween(baseDate, inputDate);
    }

    if (row[3] !== diffD || row[8] !== diffI) {
      dashboard.getRange(i + 4, 4).setValue(diffD);
      dashboard.getRange(i + 4, 9).setValue(diffI);
      applyColor(dashboard.getRange(i + 4, 1, 1, 13), diffD);
    }
  }
}

