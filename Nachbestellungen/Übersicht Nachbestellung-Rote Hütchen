function normStatusKey_(val) {
  return String(val == null ? "" : val)
    .trim()
    .toLowerCase()
    .replace(/\u00a0/g, " ")
    .replace(/\s+/g, " ");
}

function statusRank_(val) {
  const s = normStatusKey_(val);
  if (!s) return 0;
  if (s === "fertiggestellt" || s === "b2a1") return 90;
  if (s.indexOf("komplett angeliefert") !== -1 || s === "konsi-lager") return 80;
  if (s.indexOf("teilweise angeliefert") !== -1) return 60;
  if (s.indexOf("lieferr") !== -1 || s.indexOf("rueckstand") !== -1) return 55;
  if (s === "bestellt") return 50;
  if (s === "nicht bestellt") return 30;
  if (s.indexOf("nicht notwendig") !== -1) return 10;
  return 40;
}

function pickReconcileStatusPair_(nbK, nbL, exK, exL) {
  const isEmpty = function (v) {
    return v === "" || v === null || v === undefined || (typeof v === "string" && v.trim() === "");
  };
  const tsMs = function (v) {
    if (!v) return 0;
    try { return new Date(v).getTime() || 0; } catch (e) { return 0; }
  };
  const nbEmpty = isEmpty(nbK);
  const exEmpty = isEmpty(exK);
  if (nbEmpty && exEmpty) return { k: nbK, l: nbL, from: "none" };
  if (nbEmpty && !exEmpty) return { k: exK, l: exL, from: "exit" };
  if (!nbEmpty && exEmpty) return { k: nbK, l: nbL, from: "nb" };

  if (String(nbK) === String(exK)) {
    const nbDate = tsMs(nbL);
    const exDate = tsMs(exL);
    if (nbDate >= exDate) return { k: nbK, l: nbL, from: "nb" };
    return { k: exK, l: exL, from: "exit" };
  }

  const nbDate = tsMs(nbL);
  const exDate = tsMs(exL);
  let from = "nb";
  if (nbDate && !exDate) {
    from = "nb";
  } else if (exDate && !nbDate) {
    from = !isEmpty(nbK) ? "nb" : "exit";
  } else if (nbDate >= exDate) {
    from = "nb";
  } else {
    from = "exit";
  }

  let pickK = from === "nb" ? nbK : exK;
  let pickL = from === "nb" ? nbL : exL;
  const otherK = from === "nb" ? exK : nbK;
  const otherL = from === "nb" ? exL : nbL;

  if (statusRank_(pickK) <= 10 && statusRank_(otherK) >= 80) {
    pickK = otherK;
    pickL = otherL;
    from = from === "nb" ? "exit" : "nb";
  }

  return { k: pickK, l: pickL, from: from };
}

