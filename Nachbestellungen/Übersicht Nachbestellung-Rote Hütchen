function updateDashboardFromNachbestellungRow(nbSheet, row) {
  const key = String(nbSheet.getRange(row, 2).getValue() || "").trim();
  if (!key) return;
  const ss = getMainSS();
  if (!ss) return;
  const dashboard = ss.getSheetByName("Dashboard");
  if (!dashboard) return;
  const layout = getDashboardLayout(dashboard);
  const entryId = nbSheet.getRange(row, getEntryIdCol(nbSheet)).getValue() || "";

  if (entryId && isEntryIdFromInputExit(entryId)) {
    removeDashboardRowByEntryId(dashboard, entryId);
    return;
  }

  const tagesMap = getTageslisteMap();

  const dashboardRow = findRowByEntryId(dashboard, layout.cols.entryId, entryId, layout.dataStartRow);
  let fVal = "", gVal = "", hVal = "";
  if (dashboardRow !== -1) {
    const dashVals = dashboard.getRange(dashboardRow, 1, 1, layout.lastCol).getValues()[0];
    fVal = dashVals[layout.cols.herkunft - 1] || "";
    gVal = dashVals[layout.cols.etDiagnose - 1] || "";
    hVal = dashVals[layout.cols.grund - 1] || "";
  }
  const data = [
    nbSheet.getRange(row, 1).getValue(),
    key,
    "", "", "", "",
    fVal, gVal, hVal
  ];
  processRow(data, key, dashboard, nbSheet, tagesMap, "", true, entryId);
}

function deleteNachbestellungByEntryId(nbSheet, entryId) {
  if (!entryId || !nbSheet) return;
  const last = nbSheet.getLastRow();
  if (last < 2) return;
  const values = nbSheet.getRange(2, getEntryIdCol(nbSheet), last - 1, 1).getValues();
  const target = String(entryId);
  for (let i = values.length - 1; i >= 0; i--) {
    if (String(values[i][0]) === target) {
      nbSheet.deleteRow(i + 2);
    }
  }
}

function syncInputExitToZielSheetRow(inputRow) {
  try {
    const inputExit = getMainSS().getSheetByName("Input Exit");
    const stockId = String(inputExit.getRange(inputRow, 2).getValue() || "").trim().toUpperCase();
    const valueM = inputExit.getRange(inputRow, 13).getValue();
    if (!stockId || valueM === "" || valueM === null) return "Kein Wert/StockID";
    const zielSheet = SpreadsheetApp.openById(ZIELSHEET_ID).getSheetByName(ZIELSHEET_NAME);
    if (!zielSheet) return "Zielsheet nicht gefunden";
    const zielData = zielSheet.getDataRange().getValues();
    for (let i = 1; i < zielData.length; i++) {
      if (String(zielData[i][0] || "").trim().toUpperCase() === stockId) {
        zielSheet.getRange(i + 1, 5).setValue(valueM);
        return "Übertragen";
      }
    }
    return "StockID nicht gefunden";
  } catch (err) {
    return "Fehler: " + err;
  }
}

function processQueue() {
  try {
    processPendingTageslisteArchives_();
  } catch (e) {}
  const runStartTime = Date.now();
  const tagesMap = getTageslisteMap();
  const MAX_LOCK_CYCLES = 40;
  for (let k = 0; k < MAX_LOCK_CYCLES; k++) {
    const lock = LockService.getScriptLock();
    if (!lock.tryLock(QUEUE_LOCK_WAIT_MS)) return;
    let processed = 0;
    try {
      processed = runQueueProcessor(tagesMap, runStartTime) || 0;
    } finally {
      try { lock.releaseLock(); } catch (e) {}
    }
    if (processed === 0) break;
    if (Date.now() - runStartTime > QUEUE_TIME_BUDGET_MS) break;
    Utilities.sleep(150);
  }
}

function runQueueProcessor(tagesMap, runStartTime) {
  const ss = getMainSS();
  if (!ss) return 0;
  const queue = ss.getSheetByName("EventQueue");
  if (!queue) return 0;
  const last = queue.getLastRow();
  if (last < 2) return 0;

  const dashboard = ss.getSheetByName("Dashboard");
  const nbSheet = ss.getSheetByName("Nachbestellung");
  if (!dashboard || !nbSheet) return 0;

  if (!tagesMap) tagesMap = getTageslisteMap();
  if (!runStartTime) runStartTime = Date.now();
  const data = queue.getRange(1, 1, last, 10).getValues();

  const latestIdxByKey = {};
  for (let i = 1; i < data.length; i++) {
    if (data[i][6] !== "NEW") continue;
    if (data[i][1] === "_LOG") continue;
    const entryId = data[i][8] || "";
    const dedupKey = entryId
      ? "E:" + entryId
      : "S:" + (data[i][1] || "") + ":" + (data[i][2] || "");
    latestIdxByKey[dedupKey] = i;
  }

  let processedCount = 0;
  for (let i = 1; i < data.length; i++) {
    if (data[i][6] !== "NEW") continue;
    if (data[i][1] === "_LOG") continue;

    const entryId = data[i][8] || "";
    const dedupKey = entryId
      ? "E:" + entryId
      : "S:" + (data[i][1] || "") + ":" + (data[i][2] || "");

    if (latestIdxByKey[dedupKey] !== i) {
      queue.getRange(i + 1, 7).setValue("SKIPPED");
      continue;
    }

    if (Date.now() - runStartTime > QUEUE_TIME_BUDGET_MS) {
      logDebug("runQueueProcessor: Zeit-Budget erreicht, Rest beim nächsten Lauf");
      break;
    }
    if (processedCount >= QUEUE_EVENTS_PER_CYCLE) {
      break;
    }

    queue.getRange(i + 1, 7).setValue("PROCESSING");

    setLogUser(data[i][9] || "");

    try {
      const action = data[i][3];
      const snapshotKey = String(data[i][4] || "").trim();
      const sheetName = data[i][1] || "";
      const code = data[i][7] || "";
      let effectiveEntryId = entryId;

      if (!effectiveEntryId && !snapshotKey) {
        queue.getRange(i + 1, 7).setValue("DONE");
        continue;
      }

      if (action === "DELETE") {
        deleteEverywhere(snapshotKey, effectiveEntryId);
        queue.getRange(i + 1, 7).setValue("DONE");
        continue;
      }

      const inputSheet = INPUT_SHEETS[sheetName] ? ss.getSheetByName(sheetName) : null;
      let liveRow = -1;
      let liveData = null;
      let liveKey = snapshotKey;

      const inputEidCol = inputSheet ? getEntryIdCol(inputSheet) : 0;
      const queueRowNum = parseInt(data[i][2], 10) || 0;

      if (inputSheet && effectiveEntryId) {
        liveRow = findRowByEntryId(inputSheet, inputEidCol, effectiveEntryId, 2);
      }

      if (liveRow === -1 && inputSheet && queueRowNum >= 2 && snapshotKey) {
        try {
          const rowStock = String(inputSheet.getRange(queueRowNum, 2).getValue() || "").trim();
          if (rowStock.toUpperCase() === snapshotKey.toUpperCase()) {
            const rowEid = String(inputSheet.getRange(queueRowNum, inputEidCol).getValue() || "");
            liveRow = queueRowNum;
            if (rowEid) {
              if (effectiveEntryId && effectiveEntryId !== rowEid) {
                logDebug("queue: EID reconciled - queue had " + effectiveEntryId +
                  " but row " + queueRowNum + " has " + rowEid + " (using row-eid) for " + sheetName +
                  " stockId=" + snapshotKey);
              }
              effectiveEntryId = rowEid;
            } else {
              const newEid = effectiveEntryId || Utilities.getUuid();
              inputSheet.getRange(queueRowNum, inputEidCol).setValue(newEid);
              logDebug("queue: assigned EntryID " + newEid +
                " on " + sheetName + " row " + queueRowNum + " stockId=" + snapshotKey);
              effectiveEntryId = newEid;
            }
          }
        } catch (e) {}
      }

      if (liveRow === -1 && inputSheet && snapshotKey) {
        const inputLast = inputSheet.getLastRow();
        if (inputLast >= 2) {
          const stocks = inputSheet.getRange(2, 2, inputLast - 1, 1).getValues();
          const eidsCol = inputSheet.getRange(2, inputEidCol, inputLast - 1, 1).getValues();
          const target = snapshotKey.toUpperCase();
          let firstMatchRow = -1;
          let firstMatchEid = "";
          for (let r = 0; r < stocks.length; r++) {
            if (String(stocks[r][0] || "").trim().toUpperCase() === target) {
              const existingEid = String(eidsCol[r][0] || "");
              if (effectiveEntryId && existingEid === effectiveEntryId) {
                liveRow = r + 2;
                break;
              }
              if (firstMatchRow === -1) {
                firstMatchRow = r + 2;
                firstMatchEid = existingEid;
              }
            }
          }
          if (liveRow === -1 && firstMatchRow !== -1) {
            liveRow = firstMatchRow;
            if (firstMatchEid) {
              if (effectiveEntryId && effectiveEntryId !== firstMatchEid) {
                logDebug("queue: EID reconciled by stockId - queue had " + effectiveEntryId +
                  " but live row " + firstMatchRow + " has " + firstMatchEid + " for " + sheetName +
                  " stockId=" + snapshotKey);
              }
              effectiveEntryId = firstMatchEid;
            } else {
              const newEid = effectiveEntryId || Utilities.getUuid();
              inputSheet.getRange(firstMatchRow, inputEidCol).setValue(newEid);
              logDebug("queue: assigned EntryID " + newEid +
                " on " + sheetName + " row " + firstMatchRow + " (stockId fallback) stockId=" + snapshotKey);
              effectiveEntryId = newEid;
            }
          }
        }
      }

      if (liveRow !== -1) {
        liveData = inputSheet.getRange(liveRow, 1, 1, 6).getValues()[0];
        if (isInputDatumBlank(liveData[0]) && String(liveData[1] || "").trim()) {
          const now = new Date();
          inputSheet.getRange(liveRow, 1).setValue(now);
          liveData[0] = now;
        }
        const liveStock = String(liveData[1] || "").trim();
        if (liveStock) liveKey = liveStock;
        if (!effectiveEntryId) {
          effectiveEntryId = ensureEntryIdOnInputRow(inputSheet, liveRow);
        }
      } else {
        logDebug("queue: UPDATE row not found, skipping (no destructive delete). " +
          "sheet=" + sheetName + " snapshotKey=" + snapshotKey + " entryId=" + effectiveEntryId);
        queue.getRange(i + 1, 7).setValue("SKIPPED_NO_ROW");
        continue;
      }

      if (!effectiveEntryId) {
        queue.getRange(i + 1, 7).setValue("DONE");
        continue;
      }

      if (!liveKey) {
        queue.getRange(i + 1, 7).setValue("DONE");
        continue;
      }

      const rowData = liveData ? liveData.slice() : [data[i][0], snapshotKey, "", "", "", ""];
      while (rowData.length < 6) rowData.push("");

      if (sheetName === "Input Exit" || code === "EX") {
        removeDashboardRowByEntryId(dashboard, effectiveEntryId);
        applyNachbestellungState(nbSheet, liveKey, rowData, effectiveEntryId);
        queue.getRange(i + 1, 7).setValue("DONE");
        continue;
      }

      processRow(rowData, liveKey, dashboard, nbSheet, tagesMap, code, false, effectiveEntryId);
      applyNachbestellungState(nbSheet, liveKey, rowData, effectiveEntryId);

      queue.getRange(i + 1, 7).setValue("DONE");
    } catch (err) {
      queue.getRange(i + 1, 7).setValue("ERROR: " + (err && err.message ? err.message : err));
    } finally {
      setLogUser("");
      processedCount++;
    }
  }
  return processedCount;
}

function cellDateToTime(v) {
  if (v === null || v === undefined || v === "") return null;
  if (v instanceof Date) {
    return isNaN(v.getTime()) ? null : v.getTime();
  }
  const d = new Date(v);
  return isNaN(d.getTime()) ? null : d.getTime();
}

function daysBetween(d1, d2) {
  const date1 = new Date(d1.getFullYear(), d1.getMonth(), d1.getDate());
  const date2 = new Date(d2.getFullYear(), d2.getMonth(), d2.getDate());
  return Math.abs(Math.floor((date1 - date2) / (1000 * 60 * 60 * 24)));
}

function processRow(data, key, dashboard, nbSheet, tagesMap, code, forceNB, entryId) {
  if (!key) return;

  const layout = getDashboardLayout(dashboard);
  const inputDate = data[0] ? new Date(data[0]) : new Date();
  const nb = getNachbestellungValuesByKey(nbSheet, key, entryId);
  const tages = tagesMap[key.toUpperCase()] || { count: 0, lastDate: null };
  const baseDate = dashboard.getRange("A2").getValue()
    ? new Date(dashboard.getRange("A2").getValue())
    : new Date();

  let cVal, diffD, orangeC;
  if (!isStockIdInTagesliste(tages)) {
    cVal = nachbestellungFallbackFromNb(nb);
    diffD = "";
    orangeC = true;
  } else if (tages.lastDate == null || tages.lastDate === "") {
    cVal = "Kein Datum";
    diffD = "";
    orangeC = true;
  } else {
    const rowDateC = new Date(tages.lastDate);
    if (isNaN(rowDateC.getTime())) {
      cVal = "Kein Datum";
      diffD = "";
      orangeC = true;
    } else {
      cVal = tages.lastDate;
      diffD = daysBetween(baseDate, rowDateC);
      orangeC = false;
    }
  }

  const diffI = daysBetween(baseDate, inputDate);

  const found = findRowByEntryId(dashboard, layout.cols.entryId, entryId, layout.dataStartRow);

  let fVal = "", gVal = "", hVal = "";
  if (code) {
    fVal = code;
    gVal = data[2] || "";
    hVal = data[3] || "";
  } else if (found !== -1) {
    const dashVals = dashboard.getRange(found, 1, 1, layout.lastCol).getValues()[0];
    fVal = dashVals[layout.cols.herkunft - 1] || "";
    gVal = dashVals[layout.cols.etDiagnose - 1] || "";
    hVal = dashVals[layout.cols.grund - 1] || "";
  }

  const c = layout.cols;
  const out = new Array(layout.lastCol);
  for (let i = 0; i < layout.lastCol; i++) out[i] = "";

  if (found !== -1) {
    const existing = dashboard.getRange(found, 1, 1, layout.lastCol).getValues()[0];
    for (let i = 0; i < layout.lastCol; i++) out[i] = existing[i];
  }

  out[c.datum - 1] = inputDate;
  out[c.stockId - 1] = key;
  out[c.letzerTagesliste - 1] = cVal;
  out[c.tageSeitLetztem - 1] = diffD;
  out[c.eintraege - 1] = tages.count || 0;
  out[c.herkunft - 1] = fVal;
  out[c.etDiagnose - 1] = gVal;
  out[c.grund - 1] = hVal;
  out[c.tageSeitInput - 1] = diffI;
  out[c.costGate - 1] = nb.i || "";
  out[c.status - 1] = nb.k || "";
  out[c.statusAenderung - 1] = nb.l || "";
  out[c.archivieren - 1] = false;

  let targetRow;
  if (found !== -1) {
    targetRow = found;
  } else {
    targetRow = dashboard.getLastRow() + 1;
    const endData = dashboardDataEndRow(dashboard, layout);
    if (dashboard.getLastRow() >= layout.dataStartRow) {
      const allRows = dashboard.getRange(layout.dataStartRow, c.stockId, endData - layout.dataStartRow + 1, 1).getValues();
      for (let i = 0; i < allRows.length; i++) {
        if (allRows[i][0] === "" || allRows[i][0] === null) {
          targetRow = i + layout.dataStartRow;
          break;
        }
      }
    } else {
      targetRow = layout.dataStartRow;
    }
  }

  dashboard.getRange(targetRow, 1, 1, layout.lastCol).setValues([out]);
  dashboard.getRange(targetRow, c.entryId).setValue(entryId);
  dashboard.getRange(targetRow, c.letzerTagesliste).setBackground(orangeC ? "#f9cb9c" : "#ffffff");
  setDashboardTageSeitLetztemBackground(dashboard, layout, targetRow, diffD);
}

function getNachbestellungValuesByKey(nbSheet, key, entryId) {
  const empty = { i: "", k: "", l: "" };
  if (!nbSheet) return empty;
  const layout = getNachbestellungLayout(nbSheet);
  const cg = layout.cols.costGate;
  const st = layout.cols.status;
  const sa = layout.cols.statusAenderung;
  const eid = String(entryId || "").trim();
  if (eid) {
    const row = findRowByEntryId(nbSheet, layout.cols.entryId, eid, layout.dataStartRow);
    if (row !== -1) {
      const vals = nbSheet.getRange(row, cg, row, sa).getValues()[0];
      return { i: vals[0] || "", k: vals[1] || "", l: vals[2] || "" };
    }
  }
  if (!key) return empty;
  const last = nbSheet.getLastRow();
  const trim = layout.dataEndTrimBottomRows != null ? layout.dataEndTrimBottomRows : 1;
  const dataEnd = last > trim ? last - trim : last;
  if (dataEnd < layout.dataStartRow) return empty;
  const stockIdx = layout.cols.stockId;
  const keyU = String(key).trim().toUpperCase();
  const stocks = nbSheet.getRange(layout.dataStartRow, stockIdx, dataEnd, stockIdx).getValues();
  for (let i = stocks.length - 1; i >= 0; i--) {
    if (String(stocks[i][0] || "").trim().toUpperCase() === keyU) {
      const dataRow = layout.dataStartRow + i;
      const vals = nbSheet.getRange(dataRow, cg, dataRow, sa).getValues()[0];
      return { i: vals[0] || "", k: vals[1] || "", l: vals[2] || "" };
    }
  }
  return empty;
}

function getTageslisteMap() {
  const ss = SpreadsheetApp.openById(SOURCE_ID);
  const sheet = ss.getSheetByName("Tagesliste");
  const map = {};
  if (!sheet) return map;
  const last = sheet.getLastRow();
  if (last < 2) return map;
  const data = sheet.getRange(2, 1, last - 1, 5).getValues();
  for (let i = 0; i < data.length; i++) {
    const date = data[i][0];
    const key = String(data[i][4] || "").trim();
    if (!key) continue;
    const keyUpper = key.toUpperCase();
    if (!map[keyUpper]) {
      map[keyUpper] = { count: 0, lastDate: null };
    }
    map[keyUpper].count++;
    const t = cellDateToTime(date);
    if (t == null) continue;
    const prev = map[keyUpper].lastDate;
    const prevT = prev == null || prev === "" ? null : cellDateToTime(prev);
    if (prevT == null || t > prevT) {
      map[keyUpper].lastDate = date;
    }
  }
  return map;
}

function updateNachbestellung(key, data, inputDate, nbSheet, entryId) {
  if (!key || key === "Stock ID" || !entryId) return;
  if (!nbSheet) return;

  const last = nbSheet.getLastRow();
  let foundRow = -1;
  if (last >= 2) {
    foundRow = findRowByEntryId(nbSheet, getEntryIdCol(nbSheet), entryId, 2);
  }

  const nbEidCol = getEntryIdCol(nbSheet);
  const dataWidth = Math.max(14, nbEidCol - 1);
  const oldVals = foundRow !== -1 ? nbSheet.getRange(foundRow, 1, 1, dataWidth).getValues()[0] : [];
  const rowData = new Array(dataWidth);
  rowData[0] = inputDate;
  rowData[1] = key;
  rowData[2] = data[4] || "";
  rowData[3] = data[5] || "";
  rowData[4] = data[3] || "";
  for (let c = 5; c < dataWidth; c++) {
    rowData[c] = oldVals[c] != null ? oldVals[c] : "";
  }

  const targetRow = foundRow !== -1 ? foundRow : Math.max(2, nbSheet.getLastRow() + 1);
  nbSheet.getRange(targetRow, 1, 1, dataWidth).setValues([rowData]);
  nbSheet.getRange(targetRow, nbEidCol).setValue(entryId);
}

function deleteEverywhere(key, entryId) {
  const targetId = String(entryId || "").trim();
  if (!targetId) {
    logDebug("deleteEverywhere: REFUSED - no entryId. key=" + (key || "") +
      " (refusing to delete by StockID alone, would wipe duplicates with different entryIds)");
    return;
  }

  const targetKey = key ? String(key).trim().toUpperCase() : "";

  let dashRemoved = 0;
  let nbRemoved = 0;
  let inputRemoved = {};

  let ss = null;
  try { ss = getMainSS(); } catch (err) {}

  if (!ss) {
    logDebug("deleteEverywhere: cannot access main spreadsheet entryId=" + targetId);
    return;
  }

  try { uxNbStockIdLoeschungFuerWiederherstellungSpeichern_(ss, targetId, targetKey); } catch (eSnap) {}

  try {
    const dashboard = ss.getSheetByName("Dashboard");
    if (dashboard) {
      const dLayout = getDashboardLayout(dashboard);
      if (dashboard.getLastRow() >= dLayout.dataStartRow) {
        const dashEidCol = dLayout.cols.entryId;
        let dRow;
        while ((dRow = findRowByEntryId(dashboard, dashEidCol, targetId, dLayout.dataStartRow)) !== -1) {
          try {
            dashboard.deleteRow(dRow);
            dashRemoved++;
          } catch (e) {
            logDebug("deleteEverywhere dashboard delete failed row=" + dRow + ": " + e);
            break;
          }
        }
      }
    }
  } catch (err) { logDebug("deleteEverywhere dashboard error: " + err); }

  try {
    const nbSheet = ss.getSheetByName("Nachbestellung");
    if (nbSheet && nbSheet.getLastRow() >= 2) {
      const nbEidCol = getEntryIdCol(nbSheet);
      let nbRow;
      while ((nbRow = findRowByEntryId(nbSheet, nbEidCol, targetId, 2)) !== -1) {
        try {
          nbSheet.deleteRow(nbRow);
          nbRemoved++;
        } catch (e) {
          logDebug("deleteEverywhere NB delete failed row=" + nbRow + ": " + e);
          break;
        }
      }
    }
  } catch (err) { logDebug("deleteEverywhere NB error: " + err); }

  INPUT_SHEET_NAMES.forEach(function (sheetName) {
    try {
      const s = ss.getSheetByName(sheetName);
      if (!s || s.getLastRow() < 2) return;
      const inputEidCol = getEntryIdCol(s);
      let count = 0;
      let inRow;
      while ((inRow = findRowByEntryId(s, inputEidCol, targetId, 2)) !== -1) {
        try {
          s.deleteRow(inRow);
          count++;
        } catch (e) {
          logDebug("deleteEverywhere " + sheetName + " delete failed row=" + inRow + ": " + e);
          break;
        }
      }
      if (count) inputRemoved[sheetName] = count;
    } catch (err) { logDebug("deleteEverywhere " + sheetName + " error: " + err); }
  });

  logDebug("deleteEverywhere: entryId=" + targetId + " key=" + targetKey +
    " dashboard=" + dashRemoved + " nb=" + nbRemoved +
    " inputs=" + JSON.stringify(inputRemoved) +
    " (Tagesliste intentionally untouched)");
}

function inputSheetArchiveDataStart(sheetName) {
  const s = INPUT_ARCHIVE_DATA_START_ROW[sheetName];
  return s != null && s > 0 ? s : 3;
}

function inputSheetArchiveDataEnd(sheet, dataStartRow) {
  if (!sheet) return undefined;
  const last = sheet.getLastRow();
  const start = dataStartRow != null && dataStartRow > 0 ? dataStartRow : 3;
  if (last < start) return undefined;
  if (last === start) return last;
  return last - 1;
}

function archiveTemplateHeaderRange(orig, origSheetName) {
  if (!orig) return null;
  const lc = Math.max(1, orig.getLastColumn());
  if (origSheetName === "Dashboard") {
    try {
      const lo = getDashboardLayout(orig);
      const hr = lo.headerRow > 0 ? lo.headerRow : 1;
      return archiveSheetRowRange_(orig, hr, lc);
    } catch (e) {}
  }
  if (origSheetName === "Nachbestellung") {
    try {
      const lo = getNachbestellungLayout(orig);
      const hr = lo.headerRow > 0 ? lo.headerRow : 1;
      return archiveSheetRowRange_(orig, hr, lc);
    } catch (e) {}
  }
  if (origSheetName && origSheetName.indexOf("Input ") === 0) {
    const dr = inputSheetArchiveDataStart(origSheetName);
    const hr = dr > 1 ? dr - 1 : 1;
    return archiveSheetRowRange_(orig, hr, lc);
  }
  return archiveSheetRowRange_(orig, 1, lc);
}

function archiveSheetRowRange_(sheet, row, colCount) {
  const lc = Math.max(1, colCount || sheet.getLastColumn());
  return sheet.getRange(row, 1).offset(0, 0, 1, lc);
}

function ensureArchiveSheetColumns_(archive, minCols) {
  const need = Math.max(1, minCols || 1);
  const max = archive.getMaxColumns();
  if (max < need) {
    archive.insertColumnsAfter(max, need - max);
  }
}

function ensureArchiveSheetRows_(archive, minRow) {
  const need = Math.max(1, minRow || 1);
  const max = archive.getMaxRows();
  if (max < need) {
    archive.insertRowsAfter(max, need - max);
  }
}

function archiveCopyWidth_(sheet, archive, colCount) {
  const need = Math.max(1, colCount || sheet.getLastColumn());
  ensureArchiveSheetColumns_(archive, need);
  ensureArchiveSheetColumns_(sheet, need);
  return Math.min(need, sheet.getMaxColumns(), archive.getMaxColumns());
}

function archiveCopyFormattedRowToBottom(sheet, srcRow, archive, colCount) {
  const lc = archiveCopyWidth_(sheet, archive, colCount);
  let destRow = archive.getLastRow() + 1;
  if (destRow < 1) destRow = 1;
  if (archive.getLastRow() >= 1) destRow = Math.max(destRow, 2);
  ensureArchiveSheetRows_(archive, destRow);
  archiveSheetRowRange_(sheet, srcRow, lc).copyTo(archiveSheetRowRange_(archive, destRow, lc));
}

var PENDING_TAGESLISTE_ARCHIVE_PROP = "pendingTageslisteArchives";

function enqueueTageslisteArchive_(stockId) {
  const id = String(stockId || "").trim().toUpperCase();
  if (!id) return;
  const props = PropertiesService.getScriptProperties();
  let list = [];
  try {
    list = JSON.parse(props.getProperty(PENDING_TAGESLISTE_ARCHIVE_PROP) || "[]");
    if (!Array.isArray(list)) list = [];
  } catch (e) {
    list = [];
  }
  if (list.indexOf(id) === -1) list.push(id);
  props.setProperty(PENDING_TAGESLISTE_ARCHIVE_PROP, JSON.stringify(list));
}

function processPendingTageslisteArchives_() {
  const props = PropertiesService.getScriptProperties();
  let list = [];
  try {
    list = JSON.parse(props.getProperty(PENDING_TAGESLISTE_ARCHIVE_PROP) || "[]");
    if (!Array.isArray(list)) list = [];
  } catch (e) {
    list = [];
  }
  if (!list.length) return 0;
  const remaining = [];
  let done = 0;
  for (let i = 0; i < list.length; i++) {
    try {
      archiveTageslisteForStock_(list[i]);
      done++;
    } catch (e) {
      remaining.push(list[i]);
    }
  }
  props.setProperty(PENDING_TAGESLISTE_ARCHIVE_PROP, JSON.stringify(remaining));
  return done;
}

function runPendingTageslisteArchivesNow() {
  const done = processPendingTageslisteArchives_();
  try {
    SpreadsheetApp.getUi().alert("Tagesliste-Archiv: " + done + " Eintrag/Einträge verarbeitet.");
  } catch (e) {}
}

function archiveTageslisteForStock_(stockId) {
  if (!stockId) return;
  const source = SpreadsheetApp.openById(SOURCE_ID);
  if (!source.getSheetByName("Tagesliste_Archiv")) {
    const orig = source.getSheetByName("Tagesliste");
    const newSheet = source.insertSheet("Tagesliste_Archiv");
    if (orig && orig.getLastColumn() > 0) {
      const w = orig.getLastColumn();
      orig.getRange(1, 1, 1, w).copyTo(newSheet.getRange(1, 1, 1, w));
    }
  }
  moveRowToArchiveOnly(source, "Tagesliste", "Tagesliste_Archiv", 5, stockId, 2);
}

function archiveDashboardRowAt_(ss, sheet, row, layout, stockId, entryIdFilter, width) {
  if (!sheet || !row || row < layout.dataStartRow || row > sheet.getLastRow()) return false;
  const archive = ss.getSheetByName("Dashboard_Archiv");
  if (!archive) return false;
  const rowStock = String(sheet.getRange(row, layout.cols.stockId).getValue() || "").trim().toUpperCase();
  const targetStock = String(stockId).trim().toUpperCase();
  if (!rowStock || rowStock !== targetStock) return false;
  const eidNeed = entryIdFilter != null && String(entryIdFilter).trim() !== "";
  if (eidNeed) {
    const rowEid = String(sheet.getRange(row, layout.cols.entryId).getValue() || "").trim();
    if (rowEid !== String(entryIdFilter).trim()) return false;
  }
  try {
    archiveCopyFormattedRowToBottom(sheet, row, archive, width);
    sheet.deleteRow(row);
    return true;
  } catch (e) {
    try { logDebug("archiveDashboardRowAt_ row " + row + " FAILED: " + e); } catch (e2) {}
    return false;
  }
}

function archiveEntry(stockId, nachbestellungEntryId, options) {
  if (!stockId) return false;
  const ss = getMainSS();
  if (!ss) return false;
  const dashRowOpt = options && options.dashboardRow > 0 ? options.dashboardRow : 0;
  const nbEidFilter = nachbestellungEntryId != null ? String(nachbestellungEntryId).trim() : "";
  let dashboardMoved = 0;
  let nbMoved = 0;
  let inputExitMoved = 0;
  let inputQCMoved = 0;
  let inputMeMoved = 0;
  let inputLaMoved = 0;

  const archiveSheets = ["Dashboard_Archiv", "Nachbestellung_Archiv", "Input Exit_Archiv", "Input Q-Check_Archiv", "Input Mechanik_Archiv", "Input Lack_Archiv"];
  const origSheets = ["Dashboard", "Nachbestellung", "Input Exit", "Input Q-Check", "Input Mechanik", "Input Lack"];
  archiveSheets.forEach((name, idx) => {
    const origName = origSheets[idx];
    const orig = ss.getSheetByName(origName);
    let archiveSheet = ss.getSheetByName(name);
    if (!archiveSheet) {
      archiveSheet = ss.insertSheet(name);
      if (orig && orig.getLastColumn() > 0) {
        const hdr = archiveTemplateHeaderRange(orig, origName);
        if (hdr) {
          const w = hdr.getNumColumns();
          ensureArchiveSheetColumns_(archiveSheet, w);
          hdr.copyTo(archiveSheetRowRange_(archiveSheet, 1, w));
        }
      }
    } else if (orig) {
      let w = Math.max(orig.getLastColumn(), 1);
      try {
        if (origName === "Dashboard") {
          const dlo = getDashboardLayout(orig);
          if (dlo && dlo.lastCol) w = Math.max(w, dlo.lastCol);
        } else if (origName === "Nachbestellung") {
          const nlo = getNachbestellungLayout(orig);
          if (nlo && nlo.lastCol) w = Math.max(w, nlo.lastCol);
        }
      } catch (e) {}
      ensureArchiveSheetColumns_(archiveSheet, w);
    }
  });

  const dash = ss.getSheetByName("Dashboard");
  if (dash) {
    const dlo = getDashboardLayout(dash);
    const dEnd = dashboardDataEndRow(dash, dlo);
    const dashWidth = Math.max(dlo.lastCol || 0, dash.getLastColumn());
    if (dashRowOpt > 0) {
      dashboardMoved = archiveDashboardRowAt_(ss, dash, dashRowOpt, dlo, stockId, nbEidFilter, dashWidth) ? 1 : 0;
    } else if (nbEidFilter) {
      dashboardMoved = moveRowToArchiveAndDelete(ss, "Dashboard", "Dashboard_Archiv", dlo.cols.stockId, stockId, dlo.dataStartRow, dEnd, dlo.cols.entryId, nbEidFilter, dashWidth);
    } else {
      dashboardMoved = moveRowToArchiveAndDelete(ss, "Dashboard", "Dashboard_Archiv", dlo.cols.stockId, stockId, dlo.dataStartRow, dEnd, null, null, dashWidth);
    }
  }

  const nb = ss.getSheetByName("Nachbestellung");
  if (nb) {
    const nlo = getNachbestellungLayout(nb);
    const nbLast = nb.getLastRow();
    const trim = nlo.dataEndTrimBottomRows != null ? nlo.dataEndTrimBottomRows : 1;
    const nbEnd = nbLast > trim ? nbLast - trim : nbLast;
    if (nbEidFilter) {
      nbMoved = moveRowToArchiveAndDelete(ss, "Nachbestellung", "Nachbestellung_Archiv", nlo.cols.stockId, stockId, nlo.dataStartRow, nbEnd, nlo.cols.entryId, nbEidFilter);
    } else {
      try {
        logDebug("archiveEntry: skip Nachbestellung (no EntryID) stockId=" + stockId);
      } catch (e) {}
    }
  }

  const inputExit = ss.getSheetByName("Input Exit");
  const inputQC = ss.getSheetByName("Input Q-Check");
  const inputMe = ss.getSheetByName("Input Mechanik");
  const inputLa = ss.getSheetByName("Input Lack");
  const inExitStart = inputSheetArchiveDataStart("Input Exit");
  const inQCStart = inputSheetArchiveDataStart("Input Q-Check");
  const inMeStart = inputSheetArchiveDataStart("Input Mechanik");
  const inLaStart = inputSheetArchiveDataStart("Input Lack");
  inputExitMoved = moveRowToArchiveAndDelete(ss, "Input Exit", "Input Exit_Archiv", 2, stockId, inExitStart, inputSheetArchiveDataEnd(inputExit, inExitStart));
  inputQCMoved = moveRowToArchiveAndDelete(ss, "Input Q-Check", "Input Q-Check_Archiv", 2, stockId, inQCStart, inputSheetArchiveDataEnd(inputQC, inQCStart));
  inputMeMoved = moveRowToArchiveAndDelete(ss, "Input Mechanik", "Input Mechanik_Archiv", 2, stockId, inMeStart, inputSheetArchiveDataEnd(inputMe, inMeStart));
  inputLaMoved = moveRowToArchiveAndDelete(ss, "Input Lack", "Input Lack_Archiv", 2, stockId, inLaStart, inputSheetArchiveDataEnd(inputLa, inLaStart));

  enqueueTageslisteArchive_(stockId);
  try {
    const total = dashboardMoved + nbMoved + inputExitMoved + inputQCMoved + inputMeMoved + inputLaMoved;
    const detail =
      "Dashboard=" + dashboardMoved +
      " NB=" + nbMoved +
      " Exit=" + inputExitMoved +
      " QC=" + inputQCMoved +
      " ME=" + inputMeMoved +
      " LA=" + inputLaMoved;
    logDebug(
      "archiveEntry: " + (total > 0 ? "moved " + total + " row(s)" : "no rows moved") +
        " stockId=" + stockId +
        (nbEidFilter ? " entryId=" + nbEidFilter : "") +
        " (" + detail + ")"
    );
  } catch (e) {}
  return dashboardMoved > 0;
}

function moveRowToArchiveAndDelete(ss, sheetName, archiveName, keyCol, stockId, dataStartRow, dataEndRow, entryIdCol, requiredEntryId, copyWidth) {
  const sheet = ss.getSheetByName(sheetName);
  const archive = ss.getSheetByName(archiveName);
  if (!sheet || !archive) return 0;
  const last = sheet.getLastRow();
  const start = dataStartRow != null && dataStartRow > 0 ? dataStartRow : 2;
  if (last < start) return 0;
  const end = dataEndRow != null && dataEndRow >= start ? Math.min(last, dataEndRow) : last;
  if (end < start) return 0;
  const width = Math.max(copyWidth || 0, sheet.getLastColumn());
  const numRows = end - start + 1;
  const keys = sheet.getRange(start, keyCol, numRows, 1).getValues();
  const needEid = entryIdCol != null && requiredEntryId != null && String(requiredEntryId).trim() !== "";
  const eids = needEid ? sheet.getRange(start, entryIdCol, numRows, 1).getValues() : null;
  const eidTarget = needEid ? String(requiredEntryId).trim() : "";
  const target = String(stockId).trim().toUpperCase();
  let moved = 0;
  for (let r = keys.length - 1; r >= 0; r--) {
    const cell = keys[r][0];
    if (String(cell != null ? cell : "").trim().toUpperCase() !== target) continue;
    if (needEid && String(eids[r][0] != null ? eids[r][0] : "").trim() !== eidTarget) continue;
    const srcRow = start + r;
    try {
      archiveCopyFormattedRowToBottom(sheet, srcRow, archive, width);
      sheet.deleteRow(srcRow);
      moved++;
      try {
        logDebug("moveRowToArchiveAndDelete " + sheetName + " row " + srcRow + " -> " + archiveName + " stockId=" + stockId);
      } catch (eLog) {}
    } catch (e) {
      try {
        logDebug("moveRowToArchiveAndDelete " + sheetName + " row " + srcRow + " FAILED: " + e);
      } catch (e2) {}
    }
  }
  return moved;
}

function moveRowToArchiveOnly(ss, sheetName, archiveName, keyCol, stockId, dataStartRow, dataEndRow) {
  const sheet = ss.getSheetByName(sheetName);
  const archive = ss.getSheetByName(archiveName);
  if (!sheet || !archive) return;
  const last = sheet.getLastRow();
