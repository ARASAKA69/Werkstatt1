function onEdit(e) {
  if (!e || !e.range) return;
  const sheet = e.range.getSheet();
  const name = sheet.getName();
  const row = e.range.getRow();
  const col = e.range.getColumn();

  if (name === "Nachbestellung" && col === 2 && row >= 2) {
    let nbCleared = false;
    try {
      nbCleared = handleNachbestellungStockIdEdit(e, sheet, row);
    } catch (err) {
      try { logDebug("NB stockId cascade error: " + err); } catch (e) {}
    }
    if (nbCleared) return;
  }

  if (INPUT_SHEETS[name] && col === 2 && row >= 2 &&
      e.range.getNumRows() === 1 && e.range.getNumColumns() === 1) {
    let inputCleared = false;
    try {
      inputCleared = handleInputStockIdCascade(e, sheet, name, row);
    } catch (err) {
      try { logDebug("Input stockId cascade error: " + err); } catch (e2) {}
    }
    if (inputCleared) return;
  }

  withLock(function () {
    if (INPUT_SHEETS[name] && row >= 2) {
      try { ensureEntryIdsForEditRange(sheet, e.range); } catch (err) {}
    }
    handleEdit(e, sheet, name, row, col);
  }, ONEDIT_LOCK_WAIT_MS);

  try {
    mirrorNachbestellungInputExitEdits(e, sheet, name);
  } catch (err) {}

  if (INPUT_SHEETS[name] && row >= 2) {
    try {
      const range = e.range;
      const startRow = range.getRow();
      const endRow = startRow + range.getNumRows() - 1;
      for (let r = endRow; r >= startRow && r >= 2; r--) {
        enqueueInputEdit(sheet, name, r);
      }
    } catch (err) {}
  }
}

function ensureEntryIdsForEditRange(sheet, range) {
  if (!sheet || !range) return;
  const startRow = Math.max(2, range.getRow());
  const endRow = range.getRow() + range.getNumRows() - 1;
  if (endRow < startRow) return;

  const count = endRow - startRow + 1;
  const eidCol = getEntryIdCol(sheet);
  const stocks = sheet.getRange(startRow, 2, count, 1).getValues();
  const eidRange = sheet.getRange(startRow, eidCol, count, 1);
  const dateRange = sheet.getRange(startRow, 1, count, 1);
  let eids = eidRange.getValues();
  let dates = dateRange.getValues();

  let needEid = false;
  let needDate = false;
  for (let i = 0; i < count; i++) {
    if (String(stocks[i][0] || "").trim()) {
      if (!eids[i][0]) needEid = true;
      if (isInputDatumBlank(dates[i][0])) needDate = true;
    }
  }
  if (!needEid && !needDate) return;

  SpreadsheetApp.flush();
  eids = eidRange.getValues();
  dates = dateRange.getValues();

  let eidChanged = false;
  let dateChanged = false;
  const now = new Date();

  for (let i = 0; i < count; i++) {
    const stock = String(stocks[i][0] || "").trim();
    if (!stock) continue;
    if (!eids[i][0]) {
      eids[i][0] = Utilities.getUuid();
      eidChanged = true;
    }
    if (isInputDatumBlank(dates[i][0])) {
      dates[i][0] = now;
      dateChanged = true;
    }
  }

  if (eidChanged) eidRange.setValues(eids);
  if (dateChanged) dateRange.setValues(dates);
}

function ensureEntryIdAndDate(sheet, row) {
  try {
    const val = sheet.getRange(row, 2).getValue();
    if (!val) return "";
    const entryIdCell = sheet.getRange(row, getEntryIdCol(sheet));
    let eid = entryIdCell.getValue();
    if (!eid) {
      eid = Utilities.getUuid();
      entryIdCell.setValue(eid);
      logDebug("ensureEntryIdAndDate: assigned new EntryID " + eid +
        " to sheet=" + sheet.getName() + " row=" + row +
        " stockId=" + val);
    }
    const dateCell = sheet.getRange(row, 1);
    if (isInputDatumBlank(dateCell.getValue())) dateCell.setValue(new Date());
    return String(eid);
  } catch (err) {
    return "";
  }
}

function ensureEntryIdOnInputRow(sheet, row) {
  if (!sheet) return "";
  if (!INPUT_SHEETS[sheet.getName()]) return "";
  if (row < 2) return "";
  return ensureEntryIdAndDate(sheet, row);
}

const BACKFILL_TAIL_ROWS = 50;

function backfillMissingEntryIds(maxRows) {
  const ss = getMainSS();
  if (!ss) return 0;
  const tailRows = typeof maxRows === "number" && maxRows > 0 ? maxRows : BACKFILL_TAIL_ROWS;
  let totalAssigned = 0;
  INPUT_SHEET_NAMES.forEach(function (sheetName) {
    try {
      const sheet = ss.getSheetByName(sheetName);
      if (!sheet) return;
      const last = sheet.getLastRow();
      if (last < 2) return;

      const startRow = Math.max(2, last - tailRows + 1);
      const count = last - startRow + 1;
      if (count <= 0) return;

      const eidCol = getEntryIdCol(sheet);
      const stocks = sheet.getRange(startRow, 2, count, 1).getValues();
      const eids = sheet.getRange(startRow, eidCol, count, 1).getValues();

      let assigned = 0;
      for (let i = 0; i < count; i++) {
        const stock = String(stocks[i][0] || "").trim();
        const eid = String(eids[i][0] || "");
        if (stock && !eid) {
          eids[i][0] = Utilities.getUuid();
          assigned++;
        }
      }

      if (assigned > 0) {
        sheet.getRange(startRow, eidCol, count, 1).setValues(eids);
        totalAssigned += assigned;
        logDebug("backfillMissingEntryIds: " + sheetName +
          " assigned " + assigned + " EntryIDs (scanned last " + count + " rows)");
      }
    } catch (err) {
      logDebug("backfillMissingEntryIds " + sheetName + " error: " + err);
    }
  });
  return totalAssigned;
}

function backfillMissingEntryIdsFull() {
  return backfillMissingEntryIds(100000);
}

function handleEdit(e, sheet, name, row, col) {
  const range = e.range;
  const startRow = range.getRow();
  const startCol = range.getColumn();
  const endRow = startRow + range.getNumRows() - 1;
  const endCol = startCol + range.getNumColumns() - 1;

  for (let r = endRow; r >= startRow; r--) {
    handleEditPerRow(e, sheet, name, r, startCol, endCol);
  }
}

function mirrorNachbestellungInputExitEdits(e, sheet, name) {
  if (!e || !e.range || !sheet) return;
  if (name !== "Nachbestellung" && name !== "Input Exit") return;
  const range = e.range;
  const startRow = range.getRow();
  const startCol = range.getColumn();
  const endRow = startRow + range.getNumRows() - 1;
  const endCol = startCol + range.getNumColumns() - 1;
  for (let r = endRow; r >= startRow; r--) {
    mirrorNachbestellungInputExitPerRow(sheet, name, r, startCol, endCol);
  }
}

function mirrorNachbestellungInputExitPerRow(sheet, name, row, startCol, endCol) {
  const colHit = function (c) { return c >= startCol && c <= endCol; };

  if (name === "Nachbestellung" && row >= 2) {
    if (colHit(6)) {
      try { syncNachbestellungColumnToInputExit(sheet, row, 6, 7); } catch (err) { logDebug("sync NB F->Exit G failed: " + err); }
    }
    if (colHit(9)) {
      try { syncNachbestellungColumnToInputExit(sheet, row, 9, 9); } catch (err) { logDebug("sync NB I->Exit I failed: " + err); }
    }
    if (colHit(10)) {
      try { syncNachbestellungColumnToInputExit(sheet, row, 10, 10); } catch (err) { logDebug("sync NB J->Exit J failed: " + err); }
    }
    if (colHit(11)) {
      try {
        const kVal = sheet.getRange(row, 11).getValue();
        const stamp = (kVal !== "" && kVal !== null) ? new Date() : "";
        sheet.getRange(row, 12).setValue(stamp);
      } catch (err) { logDebug("set NB L date failed: " + err); }
      try { syncNachbestellungColumnToInputExit(sheet, row, 11, 11); } catch (err) { logDebug("sync NB K->Exit K failed: " + err); }
      try { syncNachbestellungColumnToInputExit(sheet, row, 12, 12); } catch (err) { logDebug("sync NB L->Exit L failed: " + err); }
    }
    if (colHit(9) || colHit(11) || colHit(12)) {
      try { updateDashboardFromNachbestellungRow(sheet, row); } catch (err) { logDebug("dashboard update failed: " + err); }
    }
  }

  if (name === "Input Exit" && row >= 2) {
    if (colHit(7)) {
      try { syncInputExitColumnToNachbestellung(sheet, row, 7, 6); } catch (err) { logDebug("sync Exit G->NB F failed: " + err); }
    }
    if (colHit(9)) {
      try { syncInputExitColumnToNachbestellung(sheet, row, 9, 9); } catch (err) { logDebug("sync Exit I->NB I failed: " + err); }
    }
    if (colHit(10)) {
      try { syncInputExitColumnToNachbestellung(sheet, row, 10, 10); } catch (err) { logDebug("sync Exit J->NB J failed: " + err); }
    }
    if (colHit(11)) {
      try {
        const kVal = sheet.getRange(row, 11).getValue();
        const stamp = (kVal !== "" && kVal !== null) ? new Date() : "";
        sheet.getRange(row, 12).setValue(stamp);
      } catch (err) {}
      try { syncInputExitColumnToNachbestellung(sheet, row, 11, 11); } catch (err) { logDebug("sync Exit K->NB K failed: " + err); }
      try { syncInputExitColumnToNachbestellung(sheet, row, 12, 12); } catch (err) { logDebug("sync Exit L->NB L failed: " + err); }
    }
  }
}

function handleEditPerRow(e, sheet, name, row, startCol, endCol) {
  const colHit = function (c) { return c >= startCol && c <= endCol; };

  if (INPUT_SHEETS[name] && colHit(2) && row >= 2) {
    const rowDeleted = handleStockIdEdit(e, sheet, row);
    if (rowDeleted) return;
  }

  if (INPUT_SHEETS[name] && row >= 2 && endCol >= 2 && startCol <= 6) {
    syncInputRowToNachbestellung(sheet, row);
  }

  if (name === "Input Exit" && row >= 2 && colHit(13)) {
    const valueM = sheet.getRange(row, 13).getValue();
    if (valueM !== "" && valueM !== null) {
      const result = syncInputExitToZielSheetRow(row);
      sheet.getRange(row, 14).setValue(result);
    } else {
      sheet.getRange(row, 14).setValue("");
    }
  }

  if (name === "Dashboard") {
    const layout = getDashboardLayout(sheet);
    if (colHit(layout.cols.archivieren) && row >= layout.dataStartRow) {
      const value = sheet.getRange(row, layout.cols.archivieren).getValue();
      const stockId = sheet.getRange(row, layout.cols.stockId).getValue();
      if (value === true && stockId) {
        archiveEntry(stockId);
        sheet.getRange(row, layout.cols.archivieren).setValue(false);
      }
    }
    return;
  }
}

function executeInputStockIdClearCascade(sheet, row, oldKey, entryIdRaw) {
  let snapshot = "";
  try {
    const snap = sheet.getRange(row, 1, 1, 6).getValues()[0];
    snapshot = JSON.stringify(snap);
  } catch (err) {}

  const entryId = String(entryIdRaw || "").trim();

  try {
    logDebug("StockID cleared -> cascade delete. sheet=" + sheet.getName() +
      " row=" + row + " oldKey=" + (oldKey || "") + " entryId=" + entryId +
      " snapshot=" + snapshot);
  } catch (err) {}

  if (entryId) {
    try { cancelPendingQueueEvents(entryId); } catch (err) {}
    try { deleteEverywhere(oldKey || "", entryId); } catch (err) {}
    return;
  }

  try { sheet.deleteRow(row); } catch (err) {}
  try { cancelPendingQueueEvents(""); } catch (err) {}
  try { deleteEverywhere(oldKey || "", ""); } catch (err) {}
}

function handleStockIdEdit(e, sheet, row) {
  let val = "";
  try { val = sheet.getRange(row, 2).getValue(); } catch (err) {}

  if (val && typeof val === "string" && val !== val.toUpperCase()) {
    try { sheet.getRange(row, 2).setValue(val.toUpperCase()); } catch (err) {}
    val = val.toUpperCase();
  }

  if (val) {
    try { applyStockIdProtection(sheet, row); } catch (err) {}
    try {
      const entryIdCell = sheet.getRange(row, getEntryIdCol(sheet));
      if (!entryIdCell.getValue()) entryIdCell.setValue(Utilities.getUuid());
    } catch (err) {}
    try {
      const dateCell = sheet.getRange(row, 1);
      if (!dateCell.getValue()) dateCell.setValue(new Date());
    } catch (err) {}
    return false;
  }

  let entryId = "";
  try { entryId = String(sheet.getRange(row, getEntryIdCol(sheet)).getValue() || "").trim(); } catch (err) {}
  const oldKey = e && e.oldValue ? String(e.oldValue) : "";
  executeInputStockIdClearCascade(sheet, row, oldKey, entryId);
  return true;
}

function handleInputStockIdCascade(e, sheet, name, row) {
