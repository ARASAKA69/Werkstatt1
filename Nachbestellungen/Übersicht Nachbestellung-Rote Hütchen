function withLock(fn, waitMs) {
  const lock = LockService.getScriptLock();
  let acquired = false;
  try {
    try { acquired = lock.tryLock(waitMs || LOCK_WAIT_MS); } catch (e) { acquired = false; }
    if (!acquired) {
      try { Logger.log("withLock: could not acquire script lock within " + (waitMs || LOCK_WAIT_MS) + "ms"); } catch (e2) {}
      return null;
    }
    return fn();
  } catch (err) {
    try { Logger.log("withLock error: " + err); } catch (e3) {}
    return null;
  } finally {
    if (acquired) {
      try { lock.releaseLock(); } catch (e) {}
    }
  }
}

function isTruthyCheckbox_(value) {
  if (value === true) return true;
  const s = String(value != null ? value : "").trim().toUpperCase();
  return s === "TRUE" || s === "WAHR" || s === "1" || s === "YES" || s === "JA";
}

function handleDashboardArchiveCheckbox_(sheet, row, layout) {
  const value = sheet.getRange(row, layout.cols.archivieren).getValue();
  const stockId = sheet.getRange(row, layout.cols.stockId).getValue();
  if (!isTruthyCheckbox_(value)) return;
  if (!String(stockId || "").trim()) {
    try { logDebug("archive checkbox row " + row + ": no stockId"); } catch (e) {}
    sheet.getRange(row, layout.cols.archivieren).setValue(false);
    return;
  }
  let entryId = "";
  try {
    entryId = sheet.getRange(row, layout.cols.entryId).getValue();
  } catch (e) {}
  try {
    logDebug("archive checkbox row " + row + " stockId=" + stockId + " entryId=" + entryId);
  } catch (e2) {}
  const archived = archiveEntry(stockId, entryId, { dashboardRow: row });
  if (!archived) {
    sheet.getRange(row, layout.cols.archivieren).setValue(false);
  }
}

function findRowByEntryId(sheet, entryIdCol, entryId, dataStartRow) {
  if (!entryId || !sheet) return -1;
  const target = String(entryId).trim();
  if (!target) return -1;
  const start = dataStartRow || 2;
  const last = sheet.getLastRow();
  if (last < start) return -1;
  const values = sheet.getRange(start, entryIdCol, last - start + 1, 1).getValues();
  for (let i = 0; i < values.length; i++) {
    if (String(values[i][0] || "").trim() === target) return i + start;
  }
  return -1;
}

function normalize(v) {
  return String(v == null ? "" : v).trim().toLowerCase();
}

function isCellFilled(v) {
  return v !== null && v !== undefined && String(v).trim() !== "";
}

function isInputDatumBlank(v) {
  if (v === null || v === undefined) return true;
  if (typeof v === "string") return v.trim() === "";
  if (v instanceof Date) return isNaN(v.getTime());
  if (typeof v === "number") return !(v > 0) || isNaN(v);
  return false;
}

function isEntryIdFromInputExit(entryId) {
  if (!entryId) return false;
  try {
    const set = buildInputExitEntryIdSet_();
    return !!set[String(entryId).trim()];
  } catch (e) {}
  return false;
}

function buildInputExitEntryIdSet_(ss) {
  const set = {};
  ss = ss || getMainSS();
  if (!ss) return set;
  const sheet = ss.getSheetByName("Input Exit");
  if (!sheet) return set;
  const last = sheet.getLastRow();
  if (last < 2) return set;
  const eidCol = getEntryIdCol(sheet);
  const vals = sheet.getRange(2, eidCol, last - 1, 1).getValues();
  for (let i = 0; i < vals.length; i++) {
    const eid = String(vals[i][0] || "").trim();
    if (eid) set[eid] = true;
  }
  return set;
}

function buildNachbestellungStatusByEntryIdMap_(nbSheet) {
  const map = {};
  if (!nbSheet) return map;
  const layout = getNachbestellungLayout(nbSheet);
  const last = nbSheet.getLastRow();
  const trim = layout.dataEndTrimBottomRows != null ? layout.dataEndTrimBottomRows : 1;
  const dataEnd = last > trim ? last - trim : last;
  if (dataEnd < layout.dataStartRow) return map;
  const width = Math.max(layout.lastCol, layout.cols.entryId, layout.cols.statusAenderung);
  const numRows = dataEnd - layout.dataStartRow + 1;
  const block = nbSheet.getRange(layout.dataStartRow, 1, numRows, width).getValues();
  const eidIdx = layout.cols.entryId - 1;
  const iIdx = layout.cols.costGate - 1;
  const kIdx = layout.cols.status - 1;
  const lIdx = layout.cols.statusAenderung - 1;
  for (let i = 0; i < block.length; i++) {
    const eid = String(block[i][eidIdx] || "").trim();
    if (!eid) continue;
    map[eid] = {
      i: block[i][iIdx] || "",
      k: block[i][kIdx] || "",
      l: block[i][lIdx] || ""
    };
  }
  return map;
}

function removeDashboardRowByEntryId(dashboard, entryId) {
  if (!dashboard || !entryId) return;
  const layout = getDashboardLayout(dashboard);
  const last = dashboard.getLastRow();
  if (last < layout.dataStartRow) return;
  const end = dashboardDataEndRow(dashboard, layout);
  try {
    const rng = dashboard.getRange(layout.dataStartRow, layout.cols.entryId, end - layout.dataStartRow + 1, 1).getValues();
    const target = String(entryId);
    for (let i = rng.length - 1; i >= 0; i--) {
      if (String(rng[i][0]) === target) {
        try { dashboard.deleteRow(i + layout.dataStartRow); } catch (e) {}
      }
    }
  } catch (e) {}
}

