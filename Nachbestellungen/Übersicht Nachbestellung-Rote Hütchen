function runSyncDashboardStatusProbe() {
  const steps = [];
  function step(name, fn) {
    try {
      fn();
      steps.push(name + ": ok");
    } catch (e) {
      steps.push(name + ": " + String(e && e.message ? e.message : e));
    }
  }
  step("getMainSS", function () {
    const ss = getMainSS();
    if (!ss) throw new Error("Hauptmappe nicht erreichbar.");
    steps.push("ss=" + ss.getName());
  });
  step("sheets", function () {
    const ss = getMainSS();
    const dashboard = ss.getSheetByName("Dashboard");
    const nbSheet = ss.getSheetByName("Nachbestellung");
    if (!dashboard || !nbSheet) throw new Error("Dashboard oder Nachbestellung fehlt.");
    steps.push("dashLast=" + dashboard.getLastRow() + " nbLast=" + nbSheet.getLastRow());
  });
  step("maps", function () {
    const ss = getMainSS();
    const exitIds = buildInputExitEntryIdSet_(ss);
    const nbSheet = ss.getSheetByName("Nachbestellung");
    const nbByEid = buildNachbestellungStatusByEntryIdMap_(nbSheet);
    steps.push("exitIds=" + Object.keys(exitIds).length + " nbMap=" + Object.keys(nbByEid).length);
  });
  const res = syncDashboardStatusFromNachbestellung(DASH_SYNC_LOCK_WAIT_MS);
  steps.push("sync=" + JSON.stringify(res));
  try { Logger.log(steps.join(" | ")); } catch (e3) {}
  return { steps: steps, sync: res };
}

