function cancelPendingQueueEvents(entryId) {
  if (!entryId) return;
  try {
    const ss = getMainSS();
    const queue = ss.getSheetByName("EventQueue");
    if (!queue) return;
    const last = queue.getLastRow();
    if (last < 2) return;
    const data = queue.getRange(2, 7, last - 1, 3).getValues();
    const target = String(entryId);
    for (let i = 0; i < data.length; i++) {
      if (data[i][0] === "NEW" && String(data[i][2]) === target) {
        queue.getRange(i + 2, 7).setValue("CANCELLED");
      }
    }
  } catch (err) {}
}

function applyStockIdProtection(sheet, row) {
  try {
    const range = sheet.getRange(row, 2);
    const protections = sheet.getProtections(SpreadsheetApp.ProtectionType.RANGE);
    for (let i = protections.length - 1; i >= 0; i--) {
      if (protections[i].getRange().getA1Notation() === range.getA1Notation()) {
        protections[i].remove();
      }
    }
    const owner = SpreadsheetApp.getActiveSpreadsheet().getOwner().getEmail();
    const protection = range.protect();
    protection.setDescription("Nur berechtigte Personen dürfen diese Stock ID ändern");
    protection.removeEditors(protection.getEditors());
    protection.addEditor(owner);
    protection.addEditor("helmut.mirbeth@auto1.com");
    protection.addEditor("bastian.frankhauser@auto1.com");
    protection.addEditor("joerg.eichenseher@auto1.com");
    protection.addEditor("tobias.nehring@auto1.com");
    protection.setWarningOnly(false);
  } catch (err) {}
}

