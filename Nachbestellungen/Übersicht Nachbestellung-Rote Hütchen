function cleanupEventQueue(ss) {
  ss = ss || getMainSS();
  if (!ss) return;
  const queue = ss.getSheetByName("EventQueue");
  if (!queue) return;
  const last = queue.getLastRow();
  if (last < 200) return;

  const data = queue.getRange(2, 1, last - 1, 7).getValues();
  const now = Date.now();
  const LOG_TTL_MS = 4 * 60 * 60 * 1000;
  const DONE_TTL_MS = 6 * 60 * 60 * 1000;

  let deleteUpTo = 0;
  for (let i = 0; i < data.length; i++) {
    const ts = data[i][0];
    const action = data[i][1];
    const status = data[i][6];
    const tsMs = ts ? new Date(ts).getTime() : 0;
    const ageMs = tsMs ? (now - tsMs) : Infinity;
    const isLog = action === "_LOG";
    const isDone = status === "DONE" || status === "SKIPPED" || status === "CANCELLED" ||
      (typeof status === "string" && status.indexOf("ERROR") === 0);

    if (isLog && ageMs > LOG_TTL_MS) {
      deleteUpTo = i + 1;
    } else if (isDone && ageMs > DONE_TTL_MS) {
      deleteUpTo = i + 1;
    } else {
      break;
    }
  }

  if (deleteUpTo > 0) {
    queue.deleteRows(2, deleteUpTo);
    Logger.log("cleanupEventQueue: " + deleteUpTo + " Zeilen entfernt");
  }
}


function reconcileNachbestellungInputExit(ss) {
  ss = ss || getMainSS();
  if (!ss) return;
  const nbSheet = ss.getSheetByName("Nachbestellung");
  const exitSheet = ss.getSheetByName("Input Exit");
  if (!nbSheet || !exitSheet) return;

  const nbLast = nbSheet.getLastRow();
  const exitLast = exitSheet.getLastRow();
  if (nbLast < 2 || exitLast < 2) return;

  const exitEids = exitSheet.getRange(2, getEntryIdCol(exitSheet), exitLast - 1, 1).getValues();
  const exitBlock = exitSheet.getRange(2, 7, exitLast - 1, 6).getValues();

  const exitByEid = {};
  for (let i = 0; i < exitEids.length; i++) {
    const eid = String(exitEids[i][0] || "");
    if (eid) exitByEid[eid] = i;
  }

  const nbEids = nbSheet.getRange(2, getEntryIdCol(nbSheet), nbLast - 1, 1).getValues();
  const nbBlockF = nbSheet.getRange(2, 6, nbLast - 1, 1).getValues();
  const nbBlockI = nbSheet.getRange(2, 9, nbLast - 1, 4).getValues();

  const isEmpty = function (v) {
    return v === "" || v === null || v === undefined || (typeof v === "string" && v.trim() === "");
  };
  const sameVal = function (a, b) {
    if (isEmpty(a) && isEmpty(b)) return true;
    if (a instanceof Date && b instanceof Date) return a.getTime() === b.getTime();
    return String(a) === String(b);
  };
  const tsMs = function (v) {
    if (!v) return 0;
    try { return new Date(v).getTime() || 0; } catch (e) { return 0; }
  };

  let nbWrites = 0;
  let exitWrites = 0;

  for (let i = 0; i < nbEids.length; i++) {
    const eid = String(nbEids[i][0] || "");
    let xi = -1;
    if (eid && (eid in exitByEid)) xi = exitByEid[eid];
    if (xi === -1) continue;

    const nbF = nbBlockF[i][0];
    const nbI = nbBlockI[i][0];
    const nbJ = nbBlockI[i][1];
    const nbK = nbBlockI[i][2];
    const nbL = nbBlockI[i][3];

    const exG = exitBlock[xi][0];
    const exI = exitBlock[xi][2];
    const exJ = exitBlock[xi][3];
    const exK = exitBlock[xi][4];
    const exL = exitBlock[xi][5];

    const picked = pickReconcileStatusPair_(nbK, nbL, exK, exL);
    const pickK = picked.k;
    const pickL = picked.l;

    if (!sameVal(nbK, pickK) || !sameVal(nbL, pickL) || !sameVal(exK, pickK) || !sameVal(exL, pickL)) {
      markReconcileWrite_();
      if (picked.from === "nb") {
        exitSheet.getRange(xi + 2, 11, 1, 2).setValues([[pickK, pickL]]);
        exitBlock[xi][4] = pickK; exitBlock[xi][5] = pickL;
        exitWrites++;
      } else if (picked.from === "exit") {
        nbSheet.getRange(i + 2, 11, 1, 2).setValues([[pickK, pickL]]);
        nbBlockI[i][2] = pickK; nbBlockI[i][3] = pickL;
        nbWrites++;
        try {
          logDebug(
            "reconcile status: entryId=" + eid +
            " NB '" + String(nbK) + "' -> '" + String(pickK) + "' (from Input Exit)"
          );
        } catch (eLog) {}
      } else if (picked.from === "nb") {
        try {
          logDebug(
            "reconcile status: entryId=" + eid +
            " Exit '" + String(exK) + "' -> '" + String(pickK) + "' (from Nachbestellung)"
          );
        } catch (eLog2) {}
      }
    }

    if (!sameVal(nbF, exG)) {
      if (isEmpty(nbF) && !isEmpty(exG)) {
        nbSheet.getRange(i + 2, 6).setValue(exG);
        nbWrites++;
      } else if (!isEmpty(nbF) && isEmpty(exG)) {
        exitSheet.getRange(xi + 2, 7).setValue(nbF);
        exitWrites++;
      }
    }
    if (!sameVal(nbI, exI)) {
      if (isEmpty(nbI) && !isEmpty(exI)) {
        nbSheet.getRange(i + 2, 9).setValue(exI);
        nbWrites++;
      } else if (!isEmpty(nbI) && isEmpty(exI)) {
        exitSheet.getRange(xi + 2, 9).setValue(nbI);
        exitWrites++;
      }
    }
    if (!sameVal(nbJ, exJ)) {
      if (isEmpty(nbJ) && !isEmpty(exJ)) {
        nbSheet.getRange(i + 2, 10).setValue(exJ);
        nbWrites++;
      } else if (!isEmpty(nbJ) && isEmpty(exJ)) {
        exitSheet.getRange(xi + 2, 10).setValue(nbJ);
        exitWrites++;
      }
    }
  }

  if (nbWrites || exitWrites) {
    logDebug("reconcileNachbestellungInputExit: NB writes=" + nbWrites + " Exit writes=" + exitWrites);
  }
}

function sameDashboardStatusDate_(a, b) {
  if (a === "" || a === null || a === undefined) {
    return b === "" || b === null || b === undefined;
  }
  if (b === "" || b === null || b === undefined) return false;
  if (a instanceof Date && b instanceof Date) return a.getTime() === b.getTime();
  return String(a) === String(b);
}

function syncDashboardStatusFromNachbestellung(waitMs) {
  const lockMs = waitMs != null ? waitMs : DASH_SYNC_LOCK_WAIT_MS;
  const lock = LockService.getScriptLock();
  if (!lock.tryLock(lockMs)) {
    return { ok: false, skipped: true, fehler: "Anderer Lauf aktiv (Lock). Bitte kurz warten und erneut versuchen." };
  }
  let updated = 0;
  let alreadyOk = 0;
  let noNbMatch = 0;
  try {
    const ss = getMainSS();
    if (!ss) return { ok: false, fehler: "Hauptmappe nicht erreichbar." };
    const dashboard = ss.getSheetByName("Dashboard");
    const nbSheet = ss.getSheetByName("Nachbestellung");
    if (!dashboard || !nbSheet) return { ok: false, fehler: "Dashboard oder Nachbestellung fehlt." };
    const dLayout = getDashboardLayout(dashboard);
    const last = dashboard.getLastRow();
    if (last < dLayout.dataStartRow) {
      return { ok: true, updated: 0, alreadyOk: 0, noNbMatch: 0, scanned: 0 };
    }
    const exitIds = buildInputExitEntryIdSet_(ss);
    const nbByEid = buildNachbestellungStatusByEntryIdMap_(nbSheet);
    const numRows = last - dLayout.dataStartRow + 1;
    const block = dashboard.getRange(dLayout.dataStartRow, 1, numRows, dLayout.lastCol).getValues();
    const cg = dLayout.cols.costGate;
    const st = dLayout.cols.status;
    const sa = dLayout.cols.statusAenderung;
    const colCg = new Array(block.length);
    const colSt = new Array(block.length);
    const colSa = new Array(block.length);
    for (let i = 0; i < block.length; i++) {
      const row = block[i];
      colCg[i] = [row[cg - 1]];
      colSt[i] = [row[st - 1]];
      colSa[i] = [row[sa - 1]];
      const entryId = String(row[dLayout.cols.entryId - 1] || "").trim();
      const stockId = String(row[dLayout.cols.stockId - 1] || "").trim();
      if (!entryId || !stockId) continue;
      if (exitIds[entryId]) continue;
      const nb = nbByEid[entryId];
      if (!nb) {
        noNbMatch++;
        continue;
      }
      const curI = row[cg - 1];
      const curK = row[st - 1];
      const curL = row[sa - 1];
      const nbHas = isCellFilled(nb.i) || isCellFilled(nb.k) || isCellFilled(nb.l);
      if (!nbHas) {
        noNbMatch++;
        continue;
      }
      if (
        String(curI) === String(nb.i) &&
        String(curK) === String(nb.k) &&
        sameDashboardStatusDate_(curL, nb.l)
      ) {
        alreadyOk++;
        continue;
      }
      colCg[i] = [nb.i];
      colSt[i] = [nb.k];
      colSa[i] = [nb.l];
      updated++;
    }
    if (updated > 0) {
      const startRow = dLayout.dataStartRow;
      const rowCount = block.length;
      dashboard.getRange(startRow, cg, rowCount, 1).setValues(colCg);
      dashboard.getRange(startRow, st, rowCount, 1).setValues(colSt);
      dashboard.getRange(startRow, sa, rowCount, 1).setValues(colSa);
      try { logDebug("syncDashboardStatusFromNachbestellung: updated " + updated + " rows"); } catch (eLog) {}
    }
    return {
      ok: true,
      updated: updated,
      alreadyOk: alreadyOk,
      noNbMatch: noNbMatch,
      scanned: block.length
    };
  } catch (err) {
    return { ok: false, fehler: String(err && err.message ? err.message : err) };
  } finally {
    try { lock.releaseLock(); } catch (e) {}
  }
}

