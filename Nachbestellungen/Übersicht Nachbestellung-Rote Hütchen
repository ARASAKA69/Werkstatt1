      tageSeitInput: 9,
      costGate: 10,
      status: 11,
      statusAenderung: 12,
      archivieren: 13,
      bemerkung: 14,
      entryId: 15
    },
    lastCol: 15
  };
}

function dashboardLayoutComplete(cols) {
  for (let i = 0; i < DASHBOARD_HEADER_KEY_LIST.length; i++) {
    if (!cols[DASHBOARD_HEADER_KEY_LIST[i]]) return false;
  }
  return true;
}

function buildDashboardLayout(dashboard) {
  const fb = defaultDashboardLayout();
  if (!dashboard) return fb;
  try {
    const lastCol = Math.max(1, dashboard.getLastColumn());
    const lastRow = Math.max(1, dashboard.getLastRow());
    const scanRows = Math.min(40, lastRow);
    let bestRow = -1;
    let bestScore = -1;
    let bestCols = null;
    for (let r = 1; r <= scanRows; r++) {
      const row = dashboard.getRange(r, 1, 1, lastCol).getValues()[0];
      const normToCol = {};
      for (let c = 0; c < lastCol; c++) {
        const n = normDashHeader(row[c]);
        if (!n) continue;
        if (normToCol[n] === undefined) normToCol[n] = c + 1;
      }
      const cols = {};
      let score = 0;
      for (let k = 0; k < DASHBOARD_HEADER_KEY_LIST.length; k++) {
        const key = DASHBOARD_HEADER_KEY_LIST[k];
        const aliases = DASHBOARD_HEADER_ALIASES[key];
        for (let a = 0; a < aliases.length; a++) {
          const idx = normToCol[normDashHeader(aliases[a])];
          if (idx) {
            cols[key] = idx;
            score++;
            break;
          }
        }
      }
      if (dashboardLayoutComplete(cols)) {
        if (score > bestScore) {
          bestScore = score;
          bestRow = r;
          bestCols = cols;
        }
      }
    }
    if (bestRow === -1 || !bestCols) return fb;
    let maxC = lastCol;
    for (let k = 0; k < DASHBOARD_HEADER_KEY_LIST.length; k++) {
      const v = bestCols[DASHBOARD_HEADER_KEY_LIST[k]];
      if (v > maxC) maxC = v;
    }
    return {
      headerRow: bestRow,
      dataStartRow: bestRow + 1,
      dataEndTrimBottomRows: 3,
      cols: bestCols,
      lastCol: Math.max(maxC, lastCol, 15)
    };
  } catch (err) {
    return fb;
  }
}

function getDashboardLayout(dashboard) {
  if (!dashboard) return defaultDashboardLayout();
  const sid = dashboard.getSheetId();
  if (_dashLayoutBySheetId[sid]) return _dashLayoutBySheetId[sid];
  const layout = buildDashboardLayout(dashboard);
  _dashLayoutBySheetId[sid] = layout;
  return layout;
}

function dashboardDataEndRow(dashboard, layout) {
  const last = dashboard.getLastRow();
  const trim = layout.dataEndTrimBottomRows != null ? layout.dataEndTrimBottomRows : 3;
  if (last < layout.dataStartRow) return last;
  return Math.max(layout.dataStartRow, last - trim);
}

function setDashboardTageSeitLetztemBackground(dashboard, layout, row, diffDays) {
  let color = "#ffffff";
  if (diffDays === "" || diffDays == null) {
    color = "#ffffff";
  } else if (diffDays <= 3) {
    color = "#d9f7d9";
  } else if (diffDays <= 10) {
    color = "#fff4cc";
  } else {
    color = "#ffd6d6";
  }
  dashboard.getRange(row, layout.cols.tageSeitLetztem).setBackground(color);
}

