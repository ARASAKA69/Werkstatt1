const ENTRYID_HEADER_PATTERNS = ["entryid", "entry id", "entry_id"];
const ENTRYID_HEADER_SEARCH_ROWS = 5;
const _entryIdColCache = {};

function defaultEntryIdCol(sheetName) {
  if (sheetName === "Dashboard") return DASHBOARD_ENTRYID_COL;
  if (sheetName === "Nachbestellung") return NB_ENTRYID_COL;
  if (INPUT_SHEETS[sheetName]) return ENTRYID_COL;
  return ENTRYID_COL;
}

function _detectEntryIdColRaw(sheet) {
  if (!sheet) return 0;
  try {
    const lastCol = sheet.getLastColumn();
    if (lastCol < 1) return 0;
    const lastRow = sheet.getLastRow();
    const scanRows = Math.min(ENTRYID_HEADER_SEARCH_ROWS, Math.max(1, lastRow));
    const headers = sheet.getRange(1, 1, scanRows, lastCol).getValues();
    for (let r = 0; r < headers.length; r++) {
      for (let c = 0; c < headers[r].length; c++) {
        const h = String(headers[r][c] || "").trim().toLowerCase().replace(/\s+/g, " ");
        if (ENTRYID_HEADER_PATTERNS.indexOf(h) !== -1) return c + 1;
      }
    }
  } catch (e) {}
  return 0;
}

function getEntryIdCol(sheet) {
  if (!sheet) return 0;
  const name = sheet.getName();
  if (_entryIdColCache[name]) return _entryIdColCache[name];
  const detected = _detectEntryIdColRaw(sheet);
  const col = detected || defaultEntryIdCol(name);
  _entryIdColCache[name] = col;
  return col;
}

function clearEntryIdColCache() {
  for (const k in _entryIdColCache) delete _entryIdColCache[k];
}

const LOCK_WAIT_MS = 30000;
const ONEDIT_LOCK_WAIT_MS = 5000;
const QUEUE_LOCK_WAIT_MS = 15000;
const CLEANUP_LOCK_WAIT_MS = 5000;
